---
interface Props {
  navn: string;
  jobbeskrivelse: string;
  billede: string;
}

const { navn, jobbeskrivelse, billede } = Astro.props;
---

<div class="flex flex-col gap-2 w-full max-w-[300px]">
  <img
    src={billede}
    alt={navn}
    class="w-full object-cover object-top aspect-[3/4]"
  />
  <div class="flex flex-col gap-0.5">
    <span class="font-mont font-normal text-[14px] text-black">{navn}</span>
    <span class="font-mont font-normal text-[12px] text-black opacity-60"
      >{jobbeskrivelse}</span
    >
  </div>
</div>
