---
import Link from "./Link.astro";
import Text from "./Text.astro";
const {
  image = "https://placehold.co/1512x808",
  imageAlt = "Tusindfryd hero",
} = Astro.props;
---

<section
  class="IndexHero sticky z-0 w-full overflow-hidden"
  style="top: var(--header-h, 78px); height: calc(100vh - var(--header-h, 78px))"
>
  <img
    src={image}
    alt={imageAlt}
    class="absolute inset-0 w-full h-full object-cover"
  />
  <div class="absolute inset-0 bg-black/10"></div>

  <div class="absolute inset-0 flex items-center px-5">
    <div class="flex justify-between items-center w-full">
      <Link
        teksttype="statement_bolder"
        stylingclasses="text-white"
        href="/shop/nyheder">NYESTE DROP</Link
      >
      <Link
        teksttype="statement_bolder"
        stylingclasses="hidden md:block text-white"
        href="/shop/sofaer">SHOP SOFAER</Link
      >
      <Link
        teksttype="statement_bolder"
        stylingclasses="hidden md:block text-white"
        href="/shop/stole">SHOP STOLE</Link
      >
      <Link
        teksttype="statement_bolder"
        stylingclasses="text-white"
        href="/shop/alt">SE ALLE PRODUKTER</Link
      >
    </div>
  </div>

  <div class="absolute bottom-5 left-5 right-5 flex flex-col md:flex-row md:justify-between md:items-end gap-2">
    <Text
      teksttype="statement_large"
      color="text-white"
      stylingclasses="max-w-[540px]"
    >
      Shop design, kvalitet og unikke fund<br />
      fundet af eksperter. Vi finder vintage - og<br />
      designmøbler fra hele verden.
    </Text>
    <Text
      teksttype="statement_bolder"
      color="text-white"
      stylingclasses="self-end md:self-auto">(SCROLL NED)</Text
    >
  </div>
</section>

<script>
  function setHeaderHeight() {
    const h = document.querySelector('header')?.offsetHeight ?? 78;
    document.documentElement.style.setProperty('--header-h', `${h}px`);
  }
  setHeaderHeight();
  window.addEventListener('resize', setHeaderHeight);
</script>
