---
import Link from "./Link.astro";
import Text from "./Text.astro";
const {
  image = "https://placehold.co/1512x808",
  imageAlt = "Tusindfryd hero",
} = Astro.props;
---

<section
  class="IndexHero sticky top-0 z-0 w-full h-[calc(100vh-108px)] overflow-hidden"
>
  <img
    src={image}
    alt={imageAlt}
    class="absolute inset-0 w-full h-full object-cover"
  />
  <div class="absolute inset-0 bg-black/10"></div>

  <div
    class="relative h-full flex flex-col justify-between pt-72 md:pt-96 px-5 pb-5"
  >
    <!-- Nav links -->
    <div class="flex justify-between items-center">
      <Link teksttype="statement_medium" stylingclasses="font-medium text-white"
        >NYESTE DROP</Link
      >
      <Link
        teksttype="statement_medium"
        stylingclasses="hidden md:block font-medium text-white"
        >SHOP SOFAER</Link
      >
      <Link
        teksttype="statement_medium"
        stylingclasses="hidden md:block font-medium text-white"
        >SHOP STOLE</Link
      >
      <Link teksttype="statement_medium" stylingclasses="font-medium text-white"
        >SE ALLE PRODUKTER</Link
      >
    </div>

    <!-- Bottom row -->
    <div class="flex flex-col md:flex-row md:justify-between md:items-end gap-2">
      <Text
        teksttype="statement_medium"
        color="text-neutral-50"
        stylingclasses="!text-2xl md:!text-3xl max-w-[540px]"
      >
        Shop design, kvalitet og unikke fund<br />
        fundet af eksperter. Vi finder vintage - og<br />
        designmøbler fra hele verden.
      </Text>
      <Text
        teksttype="statement_medium"
        color="text-neutral-50"
        stylingclasses="font-medium self-end md:self-auto"
      >(SCROLL NED)</Text>
    </div>
  </div>
</section>
