---
const {
  variant = "primary",
  href,
  target = "_self",
  teksttype = "p_large",
  stylingclasses = "",
  ...rest
} = Astro.props as {
  variant?: "primary" | "secondary" | "textlink" | "plain";
  href?: string;
  target?: string;
  teksttype?: "p_xsmall" | "p_small" | "p_medium" | "p_large" | "statement_small" | "statement_medium" | "statement_large" | "price_small" | "price_large";
  stylingclasses?: string;
  [key: string]: unknown;
};

const Tag = href ? "a" : "button";

const teksttypeClasses = {
  p_xsmall: "font-helv font-normal text-[12px]",
  p_small: "font-helv font-normal text-[13px]",
  p_medium: "font-helv font-normal text-[14px]",
  p_large: "font-helv font-light text-[14px]",
  statement_small: "font-mont font-normal text-[10px]",
  statement_medium: "font-mont font-normal text-[14px]",
  statement_large: "font-mont font-medium text-[30px]",
  price_small: "font-ibm font-normal text-[12px]",
  price_large: "font-ibm font-normal text-[14px]",
};

const variantClasses = {
  primary: "w-full bg-black text-white hover:opacity-80 transition-opacity duration-150 py-4",
  secondary: "border border-black text-black hover:bg-black hover:text-white transition-all duration-150 px-5 py-3.5",
  textlink: "text-black hover:underline transition-all duration-150",
  plain: "text-black",
};
---

<Tag
  class:list={[variantClasses[variant], teksttypeClasses[teksttype], stylingclasses]}
  href={href ?? undefined}
  target={href ? target : undefined}
  {...rest}
><slot /></Tag>
