---
const {
  href = "#",
  color = "black",
  target,
  teksttype = "p_medium",
  stylingclasses = "w-fit max-w-full",
} = Astro.props as {
  href?: string;
  color?: "black" | "white";
  target?: string;
  teksttype?: "p_medium" | "p_large";
  stylingclasses?: string;
};

const teksttypeClasses = {
  p_medium: "font-helv font-normal text-[14px]",
  p_large: "font-helv font-light text-[14px]",
};
---

<a
  href={href}
  target={target}
  rel={target === "_blank" ? "noopener noreferrer" : undefined}
  class:list={[
    "inline-flex items-end gap-[5px] pb-[1px] border-b transition-opacity duration-100 hover:opacity-90",
    color === "white" ? "border-white text-white" : "border-black text-black",
    stylingclasses,
  ]}
>
  <span class:list={[teksttypeClasses[teksttype], "min-w-0"]}><slot /></span>
  <img
    src={color === "white" ? "/svg/ArrowWhite.svg" : "/svg/ArrowBlack.svg"}
    alt=""
    aria-hidden="true"
    class="shrink-0 self-center w-[25px] h-[10px]"
  />
</a>
