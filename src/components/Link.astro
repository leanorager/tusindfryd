---
const {
  href = "#",
  target,
  teksttype = "p_medium",
  stylingclasses = "",
} = Astro.props as {
  href?: string;
  target?: string;
  teksttype?:
    | "p_xsmall"
    | "p_small"
    | "p_medium"
    | "p_large"
    | "statement_small"
    | "statement_medium"
    | "statement_bolder"
    | "statement_large"
    | "price_small"
    | "price_large";
  stylingclasses?: string;
};

const teksttypeClasses = {
  p_xsmall: "font-helv font-normal text-[12px]",
  p_small: "font-helv font-normal text-[13px]",
  p_medium: "font-helv font-normal text-[14px]",
  p_large: "font-helv font-light text-[14px]",
  statement_small: "font-mont font-normal text-[12px]",
  statement_medium: "font-mont font-normal text-[14px]",
  statement_bolder: "font-mont font-medium text-[14px]",
  statement_large: "font-mont font-normal text-[30px]",
  price_small: "font-ibm font-normal text-[12px]",
  price_large: "font-ibm font-normal text-[14px]",
};
---

<a
  href={href}
  target={target}
  class:list={[
    "hover:underline transition-all duration-150",
    teksttypeClasses[teksttype],
    stylingclasses,
  ]}><slot /></a
>
