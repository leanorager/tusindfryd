---
// Henter parametrene fra Astro.props
const {
  href = "#",
  target = "_self",
  variant = "textlink",
  size = "default",
  stylingclasses = "",
} = Astro.props as {
  href?: string;
  target?: string;
  variant?: "textlink" | "primary" | "secondary" | "plain";
  size?: "default" | "large" | "medium" | "small";
  stylingclasses?: string;
};
//Definer den styling (Tailwind classes, der gør sig gældende for alle links
const linkStyling = "hover:underline transition-all duration-150";
//Definer den styling (Tailwind classes), der gør sig gældende for de forskellige varianter
const variantClasses = {
  textlink: "font-helv font-light text-sm text-stone-800",
  primary: "font-helv font-normal text-xs text-black",
  secondary: "font-helv font-normal text-xs text-stone-600",
  plain: "",
};
//Definer den styling (Tailwind classes), der gør sig gældende for de forskellige størrelser.
const sizeClasses = {
  default: "",
  large: "text-4xl",
  medium: "text-xl",
  small: "text-sm",
};
---

<!--Sæt classes for den pågældende knap sammen ved hjælp af Astros class:list -->
<a
  href={href}
  target={target}
  class:list={[
    linkStyling,
    variantClasses[variant],
    sizeClasses[size],
    stylingclasses,
  ]}><slot /></a
>
