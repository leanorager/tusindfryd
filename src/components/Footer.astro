---

---

<footer class="bg-stone-50 border-t border-neutral-200">
  <div class="grid grid-cols-12">
    <!-- Left: logo + membership CTA -->
    <div class="col-span-12 md:col-span-4 px-5 py-12 flex flex-col gap-7">
      <img src="https://placehold.co/118x25" alt="Logo" class="w-28 h-6" />

      <div class="flex flex-col gap-2.5">
        <p class="font-helv font-light text-lg text-stone-800 max-w-xs">
          Bliv medlem og spar 10% på ALT
        </p>
        <p class="font-helv font-light text-sm text-stone-800ion-150">
          Køb medlemsskab for kun 279 DKK årligt og få altid 10% på alle ordrer
          og mange andre fordele.
        </p>
      </div>

      <!-- Button placeholder -->
      <a
        href="/bliv-medlem"
        class="w-80 h-11 px-5 py-3.5 border border-black flex justify-between items-center"
      >
        <span class="font-helv font-normal text-xs text-black">Bliv medlem</span
        >
        <span class="font-helv text-sm text-black">→</span>
      </a>
    </div>

    <!-- Showroom -->
    <div
      class="col-span-12 md:col-span-2 px-6 py-12 border-t border-neutral-200 md:border-t-0 md:border-l flex flex-col gap-5"
    >
      <span
        class="font-helv font-light text-sm text-stone-800 hover:underline transition-all duration-150"
        >Showroom</span
      >
      <div
        class="flex flex-col gap-[5px] font-helv font-light text-sm text-stone-800"
      >
        <p>Trindsøvej 10,<br />8000 Århus C</p>
        <p>Tirsdag kl 11-15</p>
        <p>Torsdag kl 14-18</p>
        <p>Lørdag kl 10-15</p>
      </div>
    </div>

    <!-- Kontakt os -->
    <div
      class="col-span-12 md:col-span-2 px-6 py-12 border-t border-neutral-200 md:border-t-0 md:border-l flex flex-col gap-5"
    >
      <span
        class="font-helv font-light text-sm text-stone-800 hover:underline transition-all duration-150"
        >Kontakt os</span
      >
      <div
        class="flex flex-col gap-[5px] font-helv font-light text-sm text-stone-800"
      >
        <a
          href="mailto:info@tusindfryd.io"
          class="hover:underline transition-all duration-150"
          >E-mail: info@tusindfryd.io</a
        >
        <p>Alle henvendelser bliver besvaret indenfor 24 timer.</p>
      </div>
    </div>

    <!-- Juridisk -->
    <div
      class="col-span-12 md:col-span-2 px-6 py-12 border-t border-neutral-200 md:border-t-0 md:border-l flex flex-col gap-5"
    >
      <span
        class="font-helv font-light text-sm text-stone-800 hover:underline transition-all duration-150"
        >Juridisk</span
      >
      <div class="flex flex-col gap-[5px]">
        <a
          href="/om"
          class="font-helv font-light text-sm text-stone-800 hover:underline transition-all duration-150"
          >Om Tusindfryd</a
        >
        <a
          href="/juridisk#ombytning"
          class="font-helv font-light text-sm text-stone-800 hover:underline transition-all duration-150"
          >Ombytnings- & returportal</a
        >
        <a
          href="/juridisk#returpolitik"
          class="font-helv font-light text-sm text-stone-800 hover:underline transition-all duration-150"
          >Returpolitik</a
        >
        <a
          href="/juridisk#privatlivspolitik"
          class="font-helv font-light text-sm text-stone-800 hover:underline transition-all duration-150"
          >Privatlivspolitik</a
        >
        <a
          href="/juridisk#handelsbetingelser"
          class="font-helv font-light text-sm text-stone-800 hover:underline transition-all duration-150"
          >Handelsbetingelser</a
        >
      </div>
    </div>

    <!-- Sociale medier -->
    <div
      class="col-span-12 md:col-span-2 px-6 py-12 border-t border-neutral-200 md:border-t-0 md:border-l flex flex-col gap-5"
    >
      <span
        class="font-helv font-light text-sm text-stone-800 hover:underline transition-all duration-150"
        >Sociale medier</span
      >
      <div class="flex flex-col gap-[5px]">
        <a
          href="#"
          class="font-helv font-light text-sm text-stone-800 hover:underline transition-all duration-150"
          >Instagram</a
        >
        <a
          href="#"
          class="font-helv font-light text-sm text-stone-800 hover:underline transition-all duration-150"
          >Facebook</a
        >
        <a
          href="#"
          class="font-helv font-light text-sm text-stone-800 hover:underline transition-all duration-150"
          >Tiktok</a
        >
        <a
          href="#"
          class="font-helv font-light text-sm text-stone-800 hover:underline transition-all duration-150"
          >Pinterest</a
        >
      </div>
    </div>
  </div>
</footer>
