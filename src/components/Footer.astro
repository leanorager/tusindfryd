---
import Text from "./Text.astro";
import Link from "./Link.astro";
import Button from "./Button.astro";
---

<footer class="bg-white border-t border-gray-200">
  <div class="grid grid-cols-12">
    <!-- Left: logo + membership CTA -->
    <div class="col-span-12 md:col-span-4 px-5 py-12 flex flex-col gap-7">
      <img src="https://placehold.co/118x25" alt="Logo" class="w-28 h-6" />

      <div class="flex flex-col gap-2.5">
        <!-- 18px light Helvetica — ingen teksttype matcher (h2_small er medium, ikke light) -->
        <p class="font-helv font-light text-lg text-gray-700 max-w-xs">
          Bliv medlem og spar 10% på ALT
        </p>
        <Text teksttype="p_large" color="text-gray-700">
          Køb medlemsskab for kun 279 DKK årligt og få altid 10% på alle ordrer
          og mange andre fordele.
        </Text>
      </div>

      <Button
        variant="secondary"
        href="/bliv-medlem"
        teksttype="p_xsmall"
        stylingclasses="w-80 h-11 flex justify-between items-center"
      >
        Bliv medlem
        <span class="font-helv text-sm">→</span>
      </Button>
    </div>

    <!-- Showroom -->
    <div
      class="col-span-12 md:col-span-2 px-6 py-12 border-t border-gray-200 md:border-t-0 md:border-l flex flex-col gap-5"
    >
      <Text teksttype="p_large" color="text-gray-700">Showroom</Text>
      <div class="flex flex-col gap-[5px]">
        <Text teksttype="p_large" color="text-gray-700">Trindsøvej 10,<br />8000 Århus C</Text>
        <Text teksttype="p_large" color="text-gray-700">Tirsdag kl 11-15</Text>
        <Text teksttype="p_large" color="text-gray-700">Torsdag kl 14-18</Text>
        <Text teksttype="p_large" color="text-gray-700">Lørdag kl 10-15</Text>
      </div>
    </div>

    <!-- Kontakt os -->
    <div
      class="col-span-12 md:col-span-2 px-6 py-12 border-t border-gray-200 md:border-t-0 md:border-l flex flex-col gap-5"
    >
      <Text teksttype="p_large" color="text-gray-700">Kontakt os</Text>
      <div class="flex flex-col gap-[5px]">
        <Link href="mailto:info@tusindfryd.io">E-mail: info@tusindfryd.io</Link>
        <Text teksttype="p_large" color="text-gray-700">
          Alle henvendelser bliver besvaret indenfor 24 timer.
        </Text>
      </div>
    </div>

    <!-- Juridisk -->
    <div
      class="col-span-12 md:col-span-2 px-6 py-12 border-t border-gray-200 md:border-t-0 md:border-l flex flex-col gap-5"
    >
      <Text teksttype="p_large" color="text-gray-700">Juridisk</Text>
      <div class="flex flex-col gap-[5px]">
        <Link href="/om">Om Tusindfryd</Link>
        <Link href="/juridisk#ombytning">Ombytnings- & returportal</Link>
        <Link href="/juridisk#returpolitik">Returpolitik</Link>
        <Link href="/juridisk#privatlivspolitik">Privatlivspolitik</Link>
        <Link href="/juridisk#handelsbetingelser">Handelsbetingelser</Link>
      </div>
    </div>

    <!-- Sociale medier -->
    <div
      class="col-span-12 md:col-span-2 px-6 py-12 border-t border-gray-200 md:border-t-0 md:border-l flex flex-col gap-5"
    >
      <Text teksttype="p_large" color="text-gray-700">Sociale medier</Text>
      <div class="flex flex-col gap-[5px]">
        <Link href="#">Instagram</Link>
        <Link href="#">Facebook</Link>
        <Link href="#">Tiktok</Link>
        <Link href="#">Pinterest</Link>
      </div>
    </div>
  </div>
</footer>
