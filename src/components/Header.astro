---
import Link from "./Link.astro";
import Text from "./Text.astro";
import Button from "./Button.astro";
---

<header
  x-data="{ shopOpen: false, cartOpen: false, menuOpen: false, searchOpen: false }"
  class="sticky top-0 z-50"
>
  <!-- Announcement bar -->
  <div
    class="bg-black text-white font-helv font-light text-xs py-2.5 flex items-center px-5"
  >
    Gratis fragt og levering for alle medlemmer
  </div>

  <!-- Nav bar -->
  <div
    class="bg-white border-b border-neutral-200 relative flex items-center h-[72px] px-5"
  >
    <Button variant="plain" @click="menuOpen = true" stylingclasses="md:hidden">
      Menu
    </Button>

    <nav class="hidden md:flex items-center gap-8">
      <Button
        variant="plain"
        @click="shopOpen = !shopOpen"
        stylingclasses="flex items-center gap-1 cursor-pointer"
      >
        Shop
        <span
          class="text-xs transition-transform duration-200"
          :class="shopOpen ? 'rotate-180' : ''">∨</span
        >
      </Button>
      <Link href="/showroom">Showroom</Link>
      <Link href="/about">Om os</Link>
    </nav>

    <a href="/" class="absolute left-1/2 -translate-x-1/2">
      <img src="/svg/logo_icon.svg" alt="Tusindfryd" class="h-8 w-auto" />
    </a>

    <!-- Mobile: Søg + Kurv -->
    <div class="md:hidden ml-auto flex items-center gap-5">
      <Button
        variant="plain"
        @click="searchOpen = true; $nextTick(() => document.getElementById('search-input')?.focus())"
        >Søg</Button
      >
      <Button variant="plain" @click="cartOpen = true">Kurv (0)</Button>
    </div>

    <!-- Desktop: utility links -->
    <nav class="hidden md:flex ml-auto items-center gap-6">
      <Button
        variant="textlink"
        stylingclasses="cursor-pointer"
        @click="searchOpen = true; $nextTick(() => document.getElementById('search-input')?.focus())"
        >Søg</Button
      >
      <Text teksttype="p_medium">
        <strong class="font-medium">DA</strong><span class="font-light">
          / EN</span
        >
      </Text>
      <Link href="/bliv-medlem">Bliv Medlem</Link>
      <Button
        variant="textlink"
        @click="cartOpen = true"
        stylingclasses="cursor-pointer">Kurv (0)</Button
      >
    </nav>
  </div>

  <!-- Mobile menu overlay -->
  <div
    x-show="menuOpen"
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition ease-in duration-200"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    class="fixed inset-0 bg-white z-50 flex flex-col md:hidden"
    style="display: none"
  >
    <div class="bg-black py-2.5 px-5 flex-shrink-0">
      <Text teksttype="p_xsmall" color="text-white" stylingclasses="font-light">
        Fragt og Levering er Gratis for alle medlemmer
      </Text>
    </div>
    <div
      class="relative flex items-center h-[72px] px-5 border-b border-neutral-200 flex-shrink-0"
    >
      <a href="/" class="absolute left-1/2 -translate-x-1/2">
        <img src="/svg/logo_icon.svg" alt="Tusindfryd" class="h-8 w-auto" />
      </a>
      <Button
        variant="plain"
        @click="menuOpen = false"
        stylingclasses="ml-auto !text-base hover:opacity-60 transition-opacity duration-150"
        >✕</Button
      >
    </div>

    <div class="flex-1 overflow-y-auto px-5 pt-8 flex flex-col">
      <p
        class="font-helv font-light text-xs text-gray-500 uppercase tracking-widest mb-4"
      >
        Shop
      </p>
      <a
        href="/shop/nyheder"
        class="font-mont font-medium text-sm text-black uppercase tracking-wide py-3 border-b border-neutral-100"
        >Nyheder</a
      >
      <a
        href="/shop/alt"
        class="font-mont font-medium text-sm text-black uppercase tracking-wide py-3 border-b border-neutral-100 mb-1"
        >Shop alt</a
      >
      <a
        href="/shop/sofaer"
        class="font-helv font-light text-sm text-black py-3 border-b border-neutral-100"
        >Sofaer</a
      >
      <a
        href="/shop/stole"
        class="font-helv font-light text-sm text-black py-3 border-b border-neutral-100"
        >Stole</a
      >
      <a
        href="/shop/borde"
        class="font-helv font-light text-sm text-black py-3 border-b border-neutral-100"
        >Borde</a
      >
      <a
        href="/shop/lamper"
        class="font-helv font-light text-sm text-black py-3 border-b border-neutral-100"
        >Lamper</a
      >
      <a
        href="/shop/taeppe"
        class="font-helv font-light text-sm text-black py-3 border-b border-neutral-100"
        >Tæpper</a
      >
      <a
        href="/shop/opbevaring"
        class="font-helv font-light text-sm text-black py-3 border-b border-neutral-100"
        >Opbevaring</a
      >
      <a
        href="/shop/andet"
        class="font-helv font-light text-sm text-black py-3 border-b border-neutral-100"
        >Andet</a
      >
      <a
        href="/showroom"
        class="font-helv font-light text-sm text-black py-3 border-b border-neutral-100 mt-6"
        >Showroom</a
      >
      <a
        href="/about"
        class="font-helv font-light text-sm text-black py-3 border-b border-neutral-100"
        >Om os</a
      >
      <a
        href="/bliv-medlem"
        class="font-helv font-light text-sm text-black py-3 border-b border-neutral-100"
        >Bliv Medlem</a
      >
    </div>

    <div
      class="px-5 py-6 flex items-center justify-between flex-shrink-0 border-t border-neutral-100"
    >
      <Button variant="plain">Søg</Button>
      <Text teksttype="p_medium">
        <strong class="font-medium">DA</strong><span class="font-light">
          / EN</span
        >
      </Text>
    </div>
  </div>

  <!-- Backdrop -->
  <div
    x-show="shopOpen || cartOpen || searchOpen"
    @click="shopOpen = false; cartOpen = false; searchOpen = false"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    class="fixed inset-0 top-[108px] bg-black/20 z-30"
  >
  </div>

  <!-- Shop dropdown -->
  <div
    x-show="shopOpen"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 -translate-y-1"
    x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100 translate-y-0"
    x-transition:leave-end="opacity-0 -translate-y-1"
    class="fixed top-[108px] left-0 w-[430px] h-[calc(100vh-108px)] bg-white z-40 flex-col border-r border-neutral-200 hidden md:flex"
  >
    <div class="flex flex-col flex-1 px-5 pt-6 overflow-y-auto">
      <a
        href="/shop/nyheder"
        class="font-mont font-medium text-sm text-black uppercase tracking-wide py-1 hover:underline transition-all duration-150"
        >Nyheder</a
      >
      <a
        href="/shop/alt"
        class="font-mont font-medium text-sm text-black uppercase tracking-wide py-1 hover:underline transition-all duration-150 mb-5"
        >Shop alt</a
      >
      <a
        href="/shop/sofaer"
        class="font-helv font-light text-sm text-black py-1 hover:underline transition-all duration-150"
        >Sofaer</a
      >
      <a
        href="/shop/stole"
        class="font-helv font-light text-sm text-black py-1 hover:underline transition-all duration-150"
        >Stole</a
      >
      <a
        href="/shop/borde"
        class="font-helv font-light text-sm text-black py-1 hover:underline transition-all duration-150"
        >Borde</a
      >
      <a
        href="/shop/lamper"
        class="font-helv font-light text-sm text-black py-1 hover:underline transition-all duration-150"
        >Lamper</a
      >
      <a
        href="/shop/taeppe"
        class="font-helv font-light text-sm text-black py-1 hover:underline transition-all duration-150"
        >Tæpper</a
      >
      <a
        href="/shop/opbevaring"
        class="font-helv font-light text-sm text-black py-1 hover:underline transition-all duration-150"
        >Opbevaring</a
      >
      <a
        href="/shop/andet"
        class="font-helv font-light text-sm text-black py-1 hover:underline transition-all duration-150"
        >Andet</a
      >
    </div>
    <div class="relative h-[220px] flex-shrink-0 overflow-hidden">
      <img
        src="https://placehold.co/430x220"
        alt="Featured kategori"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 flex justify-center items-center">
        <Text
          teksttype="p_medium"
          color="text-white"
          stylingclasses="py-0.5 border-b border-white">Shop cutlery</Text
        >
      </div>
    </div>
  </div>

  <!-- Kurv panel -->
  <div
    x-show="cartOpen"
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="translate-x-full"
    x-transition:enter-end="translate-x-0"
    x-transition:leave="transition ease-in duration-200"
    x-transition:leave-start="translate-x-0"
    x-transition:leave-end="translate-x-full"
    class="fixed top-0 right-0 w-full md:w-[420px] h-full bg-white z-50 flex flex-col border-l border-neutral-200"
  >
    <div
      class="flex justify-between items-center px-5 h-[72px] border-b border-neutral-200 flex-shrink-0"
    >
      <Text teksttype="p_large" stylingclasses="uppercase tracking-wide"
        >Din Kurv (0)</Text
      >
      <Button
        variant="plain"
        @click="cartOpen = false"
        stylingclasses="!text-base hover:opacity-60 transition-opacity duration-150 cursor-pointer"
        >✕</Button
      >
    </div>
    <div class="flex-1 flex items-center justify-center p-5">
      <Text teksttype="p_large" color="text-gray-500">Din kurv er tom.</Text>
    </div>
    <div class="p-5 border-t border-neutral-200 flex-shrink-0">
      <Button variant="primary">GÅ TIL KASSE</Button>
    </div>
  </div>

  <!-- Søg panel -->
  <div
    x-show="searchOpen"
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="translate-x-full"
    x-transition:enter-end="translate-x-0"
    x-transition:leave="transition ease-in duration-200"
    x-transition:leave-start="translate-x-0"
    x-transition:leave-end="translate-x-full"
    class="fixed top-0 right-0 w-full md:w-[420px] h-full bg-white z-50 flex flex-col border-l border-neutral-200"
    @keydown.escape.window="searchOpen = false"
  >
    <div
      class="flex justify-between items-center px-5 h-[72px] border-b border-neutral-200 flex-shrink-0"
    >
      <Text teksttype="p_large" stylingclasses="uppercase tracking-wide"
        >Søg</Text
      >
      <Button
        variant="plain"
        @click="searchOpen = false"
        stylingclasses="!text-base hover:opacity-60 transition-opacity duration-150 cursor-pointer"
        >✕</Button
      >
    </div>

    <div class="px-5 pt-6 flex-shrink-0">
      <input
        id="search-input"
        type="text"
        placeholder="Søg efter produkt eller designer..."
        class="w-full border-b border-neutral-300 pb-3 font-helv font-light text-sm outline-none placeholder:text-gray-400 focus:border-black transition-colors duration-150"
      />
    </div>

    <div id="search-results" class="flex-1 overflow-y-auto px-5 pt-4"></div>

    <div
      id="search-footer"
      style="display:none"
      class="flex-shrink-0 border-t border-neutral-100 p-4"
    >
      <a
        id="search-see-all"
        href="/search"
        class="block w-full border border-black py-4 font-helv font-normal text-[13px] text-center hover:bg-black hover:text-white transition-colors duration-150"
      >
        SE ALLE
      </a>
    </div>
  </div>
</header>

<script>
  const SUPABASE_URL = "https://txfouhhxrpcyrsvjnnpd.supabase.co/rest/v1";
  const SUPABASE_KEY =
    "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InR4Zm91aGh4cnBjeXJzdmpubnBkIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzgzNjc2MTcsImV4cCI6MjA5Mzk0MzYxN30.SdHA98ZoF-4DMTXeZc59-jpHjD4rnFdqcuQw-MqmpQI";

  type SearchProduct = {
    id: number;
    title: string;
    subtitle: string;
    regular_price: number;
    image1: string | null;
    category: string[] | null;
    material_tag: string[] | null;
  };

  let cachedProducts: SearchProduct[] | null = null;

  async function getProducts(): Promise<SearchProduct[]> {
    if (cachedProducts) return cachedProducts;
    const res = await fetch(
      `${SUPABASE_URL}/products?select=id,title,subtitle,regular_price,image1,category,material_tag`,
      {
        headers: {
          apikey: SUPABASE_KEY,
          Authorization: `Bearer ${SUPABASE_KEY}`,
        },
      },
    );
    cachedProducts = await res.json();
    return cachedProducts!;
  }

  function formatPrice(price: number) {
    return new Intl.NumberFormat("da-DK").format(price) + " DKK";
  }

  let debounceTimer: ReturnType<typeof setTimeout>;

  const POPULAR_SEARCHES = ["Sofa", "Stol", "Lampe", "Bord"];

  function showPopularSearches(
    resultsEl: HTMLElement,
    footer: HTMLElement | null,
  ) {
    resultsEl.innerHTML = `
      <h3 class="font-helv font-medium text-[12px] uppercase mb-4">Populære søgninger</h3>
      <div class="flex flex-wrap gap-x-6 gap-y-2">
        ${POPULAR_SEARCHES.map(
          (term) => `<a href="/shop/search?q=${encodeURIComponent(term)}"
            class="hover:underline transition-all duration-150 font-helv font-light text-sm text-gray-700">${term}</a>`,
        ).join("")}
      </div>
    `;
    if (footer) footer.style.display = "none";
  }

  async function runSearch(query: string) {
    const resultsEl = document.getElementById("search-results");
    const footer = document.getElementById("search-footer");
    const seeAllLink = document.getElementById(
      "search-see-all",
    ) as HTMLAnchorElement | null;
    if (!resultsEl) return;

    if (!query) {
      showPopularSearches(resultsEl, footer);
      return;
    }

    const q = query.toLowerCase();
    const products = await getProducts();
    const matches = products
      .filter(
        (p) =>
          p.title?.toLowerCase().includes(q) ||
          p.subtitle?.toLowerCase().includes(q) ||
          p.category?.some((c) => c.toLowerCase().includes(q)) ||
          p.material_tag?.some((m) => m.toLowerCase().includes(q)),
      )
      .slice(0, 8);

    if (matches.length === 0) {
      resultsEl.innerHTML = `<p class="font-helv font-light text-sm text-gray-400 pt-2">Ingen resultater for "${query}"</p>`;
      if (footer) footer.style.display = "none";
      return;
    }

    resultsEl.innerHTML = matches
      .map(
        (p) => `
        <a href="/product/${p.id}" class="flex items-center gap-4 py-4 border-b border-neutral-100 hover:opacity-60 transition-opacity duration-150">
          <img
            src="${p.image1 ?? "https://placehold.co/56x56"}"
            alt="${p.title}"
            class="w-14 h-14 object-cover flex-shrink-0"
          />
          <div class="flex-1 min-w-0">
            <p class="font-helv font-medium text-sm text-black truncate">${p.title}</p>
            <p class="font-helv font-light text-xs text-gray-500 truncate">${p.subtitle}</p>
          </div>
          <p class="font-ibm font-normal text-sm text-black flex-shrink-0">${formatPrice(p.regular_price)}</p>
        </a>
      `,
      )
      .join("");

    if (seeAllLink)
      seeAllLink.href = `/shop/search?q=${encodeURIComponent(query)}`;
    if (footer) footer.style.display = "";
  }

  document.addEventListener("DOMContentLoaded", () => {
    const input = document.getElementById(
      "search-input",
    ) as HTMLInputElement | null;
    if (!input) return;

    // Show popular searches on load so they're ready when the panel opens
    runSearch("");

    input.addEventListener("input", (e) => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => {
        runSearch((e.target as HTMLInputElement).value.trim());
      }, 250);
    });

    input.addEventListener("keydown", (e) => {
      if (e.key === "Enter") {
        const q = input.value.trim();
        if (q) window.location.href = `/shop/search?q=${encodeURIComponent(q)}`;
      }
    });
  });
</script>
