---
import Link from "./Link.astro";
import Heading from "./Heading.astro";
import Text from "./Text.astro";
import Button from "./Button.astro";
---

<header
  x-data="{ shopOpen: false, menuOpen: false, searchOpen: false, formatPrice(p) { return new Intl.NumberFormat('da-DK').format(p) + ' DKK'; } }"
  class="sticky top-0 z-50"
>
  <!-- Announcement bar -->
  <div
    class="bg-black py-[7px] flex items-baseline px-container flex-row gap-2xs"
  >
    <Text teksttype="p_small" color="text-white"> 4.7 </Text>
    <img
      src="/svg/star.svg"
      alt="stjerne"
      class="h-[12px] w-auto self-center"
    />
    <Text teksttype="p_small" color="text-white">
      på Trustpilot - Gratis levering til medlemmer
    </Text>
  </div>

  <!-- Nav bar -->
  <div
    class="bg-white border-b border-neutral-200 relative flex items-center py-container-mobile px-container"
  >
    <Button variant="plain" @click="menuOpen = true" stylingclasses="md:hidden">
      <img src="/svg/burger-icon.svg" alt="Menu" class="h-[18px] w-auto" />
    </Button>

    <nav class="hidden md:flex items-center gap-m">
      <Button
        variant="plain"
        @click="shopOpen = !shopOpen"
        stylingclasses="flex items-center gap-2xs cursor-pointer"
      >
        Shop
        <img
          src="/svg/arrow-down.svg"
          alt=""
          class="h-[5px] w-auto transition-transform duration-200"
          :class="shopOpen ? 'rotate-180' : ''"
        />
      </Button>
      <Link stylingclasses="text-gray-700" href="/showroom">Showroom</Link>
      <Link stylingclasses="text-gray-700" href="/about">Om os</Link>
    </nav>

    <a href="/" class="absolute left-1/2 -translate-x-1/2">
      <img src="/svg/logo_icon.svg" alt="Tusindfryd" class="h-[29px] w-auto" />
    </a>

    <!-- Mobile: Søg + Kurv -->
    <div class="md:hidden ml-auto flex items-center gap-s">
      <Button
        variant="plain"
        @click="searchOpen = true; $nextTick(() => document.getElementById('search-input')?.focus())"
      >
        <img src="/svg/search-icon.svg" alt="Søg" class="h-[18px] w-auto" />
      </Button>
      <Button
        teksttype="p_xsmall"
        variant="plain"
        @click="$store.cart.open = true"
        >Kurv (<span x-text="$store.cart.items.length">0</span>)</Button
      >
    </div>

    <!-- Desktop: utility links -->
    <nav class="hidden md:flex ml-auto items-center gap-m">
      <Button
        variant="textlink"
        stylingclasses="cursor-pointer"
        @click="searchOpen = true; $nextTick(() => document.getElementById('search-input')?.focus())"
        >Søg</Button
      >
      <Text teksttype="p_medium" stylingclasses="text-gray-700">
        <strong>DA</strong><span class="font-light"> / EN</span>
      </Text>
      <Link stylingclasses="text-gray-700" href="/bliv-medlem">Bliv Medlem</Link
      >
      <Button
        variant="textlink"
        @click="$store.cart.open = true"
        stylingclasses="cursor-pointer"
        >Kurv (<span x-text="$store.cart.items.length">0</span>)</Button
      >
    </nav>
  </div>

  <!-- Mobile burgermenu overlay -->
  <div
    x-show="menuOpen"
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition ease-in duration-200"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    class="fixed inset-0 bg-white z-50 flex flex-col md:hidden"
    style="display: none"
  >
    <!-- Announcement bar -->
    <div class="bg-black py-[7px] flex items-center px-container flex-shrink-0">
      <Text teksttype="p_small" color="text-white">
        Gratis fragt og levering for alle medlemmer
      </Text>
    </div>

    <!-- Nav bar -->
    <div
      class="bg-white border-b border-neutral-200 relative flex items-center py-container-mobile px-container flex-shrink-0"
    >
      <Button
        variant="plain"
        @click="menuOpen = false"
        stylingclasses="leading-[18px]">✕</Button
      >
      <a href="/" class="absolute left-1/2 -translate-x-1/2">
        <img
          src="/svg/logo_icon.svg"
          alt="Tusindfryd"
          class="h-[29px] w-auto"
        />
      </a>
      <div class="ml-auto flex items-center gap-s">
        <Button
          variant="plain"
          @click="menuOpen = false; searchOpen = true; $nextTick(() => document.getElementById('search-input')?.focus())"
        >
          <img src="/svg/search-icon.svg" alt="Søg" class="h-[18px] w-auto" />
        </Button>
        <Button
          teksttype="p_xsmall"
          variant="plain"
          @click="menuOpen = false; $store.cart.open = true"
          >Kurv (<span x-text="$store.cart.items.length">0</span>)</Button
        >
      </div>
    </div>

    <!-- Menu content -->
    <div class="flex-1 overflow-y-auto flex flex-col">
      <div class="flex flex-col px-container pt-s flex-1">
        <a
          href="/shop/nyheder"
          class="font-helv font-medium text-[18px] text-black uppercase tracking-wide py-1 hover:underline transition-all duration-150"
          >Nyheder</a
        >
        <a
          href="/shop/alt"
          class="font-helv font-medium text-[18px] text-black uppercase tracking-wide py-1 hover:underline transition-all duration-150 mb-5"
          >Shop alt</a
        >
        <div class="flex flex-col gap-xs mb-m">
          <Link href="/shop/sofaer" teksttype="p_large">Sofaer</Link>
          <Link href="/shop/stole" teksttype="p_large">Stole</Link>
          <Link href="/shop/borde" teksttype="p_large">Borde</Link>
          <Link href="/shop/lamper" teksttype="p_large">Lamper</Link>
          <Link href="/shop/taeppe" teksttype="p_large">Tæpper</Link>
          <Link href="/shop/opbevaring" teksttype="p_large">Opbevaring</Link>
          <Link href="/shop/andet" teksttype="p_large">Andet</Link>
        </div>
        <div class="flex flex-col gap-xs">
          <Link href="/showroom" teksttype="p_large">Showroom</Link>
          <Link href="/about" teksttype="p_large">Om os</Link>
          <Link href="/bliv-medlem" teksttype="p_large">Bliv Medlem</Link>
        </div>
      </div>

      <!-- Bliv medlem billede -->
      <div class="relative h-[371px] flex-shrink-0 overflow-hidden">
        <a href="/bliv-medlem" class="group">
          <img
            src="/img/shop-panel.webp"
            alt="Bliv medlem og få fordele"
            class="w-full h-full object-cover transition-transform duration-700 ease-in-out group-hover:scale-105"
          />
          <div class="absolute inset-0 flex justify-center items-center">
            <Text
              teksttype="p_medium"
              color="text-white"
              stylingclasses="py-0.5 border-b border-white">Bliv medlem</Text
            >
          </div>
        </a>
      </div>
    </div>
  </div>

  <!-- Backdrop -->
  <div
    x-show="shopOpen || $store.cart.open || searchOpen"
    @click="shopOpen = false; $store.cart.open = false; searchOpen = false"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    class="fixed inset-0 top-[78px] z-30 bg-black/10 backdrop-blur-lg"
  >
  </div>

  <!-- Shop dropdown -->
  <div
    x-show="shopOpen"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 -translate-y-1"
    x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100 translate-y-0"
    x-transition:leave-end="opacity-0 -translate-y-1"
    class="fixed top-[76px] left-0 w-[430px] h-[calc(100vh-76px)] bg-white z-40 flex-col border-r border-neutral-200 hidden md:flex"
  >
    <div class="flex flex-col flex-1 px-container pt-s overflow-y-auto">
      <a
        href="/shop/nyheder"
        class="font-helv font-medium text-[18px] text-black uppercase tracking-wide py-1 hover:underline transition-all duration-150"
        >Nyheder</a
      >
      <a
        href="/shop/alt"
        class="font-helv font-medium text-[18px] text-black uppercase tracking-wide py-1 hover:underline transition-all duration-150 mb-5"
        >Shop alt</a
      >
      <div class="flex flex-col gap-[8px]">
        <Link href="/shop/sofaer" teksttype="p_large">Sofaer</Link>
        <Link href="/shop/stole" teksttype="p_large">Stole</Link>
        <Link href="/shop/borde" teksttype="p_large">Borde</Link>
        <Link href="/shop/lamper" teksttype="p_large">Lamper</Link>
        <Link href="/shop/taeppe" teksttype="p_large">Tæpper</Link>
        <Link href="/shop/opbevaring" teksttype="p_large">Opbevaring</Link>
        <Link href="/shop/andet" teksttype="p_large">Andet</Link>
      </div>
    </div>
    <div class="relative h-[371px] flex-shrink-0 overflow-hidden">
      <a href="/bliv-medlem" class="group">
        <img
          src="/img/shop-panel.webp"
          alt="Bliv medlem"
          class="w-full h-full object-cover transition-transform duration-700 ease-in-out group-hover:scale-105"
        />
        <div class="absolute inset-0 flex justify-center items-center">
          <Text
            teksttype="p_medium"
            color="text-white"
            stylingclasses="py-0.5 border-b border-white transition-opacity duration-300 group-hover:opacity-70"
            >Bliv medlem</Text
          >
        </div>
      </a>
    </div>
  </div>

  <!-- Kurv panel -->
  <div
    x-show="$store.cart.open"
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="translate-x-full"
    x-transition:enter-end="translate-x-0"
    x-transition:leave="transition ease-in duration-200"
    x-transition:leave-start="translate-x-0"
    x-transition:leave-end="translate-x-full"
    class="fixed top-0 right-0 w-full md:w-[420px] h-full bg-white z-50 flex flex-col border-l border-neutral-200"
    style="display:none"
  >
    <!-- Panel header -->
    <div
      class="flex justify-between items-center px-5 h-[78px] border-b border-neutral-200 flex-shrink-0"
    >
      <Heading
        type="h4"
        htmlheading="h4"
        stylingclasses="uppercase tracking-wide"
      >
        Kurv (<span x-text="$store.cart.items.length">0</span>)
      </Heading>
      <Button
        variant="plain"
        @click="$store.cart.open = false"
        stylingclasses="!text-base hover:opacity-60 transition-opacity duration-150 cursor-pointer"
        >✕</Button
      >
    </div>

    <!-- Tom kurv -->
    <div
      x-show="$store.cart.items.length === 0"
      class="flex-1 flex items-center justify-center p-5"
    >
      <Text teksttype="p_large" color="text-gray-500">Din kurv er tom.</Text>
    </div>

    <!-- Vareliste -->
    <div
      x-show="$store.cart.items.length > 0"
      class="flex-1 overflow-y-auto"
      style="display:none"
    >
      <template x-for="item in $store.cart.items" :key="item.id">
        <div
          class="flex items-start gap-4 px-5 py-4 border-b border-neutral-100"
        >
          <img
            :src="item.image || 'https://placehold.co/80x100'"
            :alt="item.title"
            class="w-[80px] h-[100px] object-cover flex-shrink-0"
          />
          <div class="flex-1 min-w-0 pt-1">
            <p
              class="font-helv font-medium text-[14px] text-black leading-tight mb-1"
              x-text="item.title"
            >
            </p>
            <p
              class="font-helv font-light text-[12px] text-gray-500 leading-tight"
              x-text="item.subtitle"
            >
            </p>
          </div>
          <div
            class="flex flex-col items-end justify-between h-[100px] flex-shrink-0"
          >
            <p
              class="font-ibm font-normal text-[14px] text-black"
              x-text="formatPrice(item.price)"
            >
            </p>
            <button
              @click="$store.cart.remove(item.id)"
              class="font-helv font-light text-[16px] text-gray-400 hover:text-black transition-colors duration-150 cursor-pointer"
              >✕</button
            >
          </div>
        </div>
      </template>
    </div>

    <!-- Footer: total + knap -->
    <div
      x-show="$store.cart.items.length > 0"
      class="flex-shrink-0 border-t border-neutral-200 px-5 pt-4 pb-6"
      style="display:none"
    >
      <div class="flex justify-between items-center mb-1">
        <span class="font-helv font-normal text-[14px]">Total</span>
        <span
          class="font-ibm font-normal text-[14px]"
          x-text="formatPrice($store.cart.total)"></span>
      </div>
      <div class="flex justify-between items-center mb-5">
        <span class="font-helv font-light text-[12px] text-gray-500">
          Standard Levering <span class="text-gray-400"
            >(1-2 dages levering)</span
          >
        </span>
        <span class="font-helv font-normal text-[12px] text-green-600"
          >Gratis</span
        >
      </div>
      <button
        class="w-full bg-black text-white font-helv font-normal text-[13px] uppercase tracking-wide py-4 hover:opacity-80 transition-opacity duration-150 cursor-pointer"
        x-text="`GÅ TIL KASSE  -  ${formatPrice($store.cart.total)}`"></button>
    </div>
  </div>

  <!-- Søg panel -->
  <div
    x-show="searchOpen"
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="translate-x-full"
    x-transition:enter-end="translate-x-0"
    x-transition:leave="transition ease-in duration-200"
    x-transition:leave-start="translate-x-0"
    x-transition:leave-end="translate-x-full"
    class="fixed top-0 right-0 w-full md:w-[420px] h-full bg-white z-50 flex flex-col border-l border-neutral-200"
    @keydown.escape.window="searchOpen = false"
  >
    <div
      class="flex justify-between items-center px-5 h-[78px] border-b border-neutral-200 flex-shrink-0"
    >
      <Heading
        type="h4"
        htmlheading="h4"
        stylingclasses="uppercase tracking-wide">Søg</Heading
      >
      <Button
        variant="plain"
        @click="searchOpen = false"
        stylingclasses="!text-base hover:opacity-60 transition-opacity duration-150 cursor-pointer"
        >✕</Button
      >
    </div>

    <div class="px-5 pt-6 flex-shrink-0">
      <input
        id="search-input"
        type="text"
        placeholder="Søg efter produkt eller designer..."
        class="w-full border-b border-neutral-300 pb-3 font-helv font-light text-[14px] outline-none placeholder:text-gray-400 focus:border-black transition-colors duration-150"
      />
    </div>

    <div id="search-results" class="flex-1 overflow-y-auto px-5 pt-4"></div>

    <div
      id="search-footer"
      style="display:none"
      class="flex-shrink-0 border-t border-neutral-100 p-4"
    >
      <a
        id="search-see-all"
        href="/search"
        class="block w-full border border-black py-4 font-helv font-normal text-[13px] text-center hover:bg-black hover:text-white transition-colors duration-150"
      >
        SE ALLE
      </a>
    </div>
  </div>

  <script>
    const SUPABASE_URL = "https://txfouhhxrpcyrsvjnnpd.supabase.co/rest/v1";
    const SUPABASE_KEY =
      "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InR4Zm91aGh4cnBjeXJzdmpubnBkIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzgzNjc2MTcsImV4cCI6MjA5Mzk0MzYxN30.SdHA98ZoF-4DMTXeZc59-jpHjD4rnFdqcuQw-MqmpQI";

    type SearchProduct = {
      id: number;
      title: string;
      subtitle: string;
      regular_price: number;
      image1: string | null;
      category: string[] | null;
      material_tag: string[] | null;
    };

    let cachedProducts: SearchProduct[] | null = null;

    async function getProducts(): Promise<SearchProduct[]> {
      if (cachedProducts) return cachedProducts;
      const res = await fetch(
        `${SUPABASE_URL}/products?select=id,title,subtitle,regular_price,image1,category,material_tag`,
        {
          headers: {
            apikey: SUPABASE_KEY,
            Authorization: `Bearer ${SUPABASE_KEY}`,
          },
        },
      );
      cachedProducts = await res.json();
      return cachedProducts!;
    }

    function formatPrice(price: number) {
      return new Intl.NumberFormat("da-DK").format(price) + " DKK";
    }

    let debounceTimer: ReturnType<typeof setTimeout>;

    const POPULAR_SEARCHES = ["Sofa", "Stol", "Lampe", "Bord"];

    function showPopularSearches(
      resultsEl: HTMLElement,
      footer: HTMLElement | null,
    ) {
      resultsEl.innerHTML = `
      <h3 class="font-helv font-medium text-[12px] uppercase mb-4">Populære søgninger</h3>
      <div class="flex flex-wrap gap-x-6 gap-y-2">
        ${POPULAR_SEARCHES.map(
          (term) => `<a href="/shop/search?q=${encodeURIComponent(term)}"
            class="hover:underline transition-all duration-150 font-helv font-light text-[14px] text-gray-700">${term}</a>`,
        ).join("")}
      </div>
    `;
      if (footer) footer.style.display = "none";
    }

    async function runSearch(query: string) {
      const resultsEl = document.getElementById("search-results");
      const footer = document.getElementById("search-footer");
      const seeAllLink = document.getElementById(
        "search-see-all",
      ) as HTMLAnchorElement | null;
      if (!resultsEl) return;

      if (!query) {
        showPopularSearches(resultsEl, footer);
        return;
      }

      const q = query.toLowerCase();
      const products = await getProducts();
      const matches = products
        .filter(
          (p) =>
            p.title?.toLowerCase().includes(q) ||
            p.subtitle?.toLowerCase().includes(q) ||
            p.category?.some((c) => c.toLowerCase().includes(q)) ||
            p.material_tag?.some((m) => m.toLowerCase().includes(q)),
        )
        .slice(0, 8);

      if (matches.length === 0) {
        resultsEl.innerHTML = `<p class="font-helv font-light text-sm text-gray-400 pt-2">Ingen resultater for "${query}"</p>`;
        if (footer) footer.style.display = "none";
        return;
      }

      resultsEl.innerHTML = matches
        .map(
          (p) => `
        <a href="/product/${p.id}" class="flex items-center gap-4 py-4 border-b border-neutral-100 hover:opacity-60 transition-opacity duration-150">
          <img
            src="${p.image1 ?? "https://placehold.co/56x56"}"
            alt="${p.title}"
            class="w-14 h-14 object-cover flex-shrink-0"
          />
          <div class="flex-1 min-w-0">
            <p class="font-helv font-medium text-sm text-black truncate">${p.title}</p>
            <p class="font-helv font-light text-xs text-gray-500 truncate">${p.subtitle}</p>
          </div>
          <p class="font-ibm font-normal text-sm text-black flex-shrink-0">${formatPrice(p.regular_price)}</p>
        </a>
      `,
        )
        .join("");

      if (seeAllLink)
        seeAllLink.href = `/shop/search?q=${encodeURIComponent(query)}`;
      if (footer) footer.style.display = "";
    }

    document.addEventListener("DOMContentLoaded", () => {
      const input = document.getElementById(
        "search-input",
      ) as HTMLInputElement | null;
      if (!input) return;

      // Show popular searches on load so they're ready when the panel opens
      runSearch("");

      input.addEventListener("input", (e) => {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(() => {
          runSearch((e.target as HTMLInputElement).value.trim());
        }, 250);
      });

      input.addEventListener("keydown", (e) => {
        if (e.key === "Enter") {
          const q = input.value.trim();
          if (q)
            window.location.href = `/shop/search?q=${encodeURIComponent(q)}`;
        }
      });
    });
  </script>
</header>
