---
import Link from "./Link.astro";
import Text from "./Text.astro";
import Button from "./Button.astro";
---

<header
  x-data="{ shopOpen: false, cartOpen: false, menuOpen: false }"
  class="sticky top-0 z-50"
>
  <!-- Announcement bar -->
  <div class="bg-black py-2.5 flex items-center px-5">
    <Text teksttype="p_xsmall" color="text-white" stylingclasses="font-light">
      Fragt og Levering er Gratis for alle medlemmer
    </Text>
  </div>

  <!-- Nav bar -->
  <div
    class="bg-white border-b border-neutral-200 relative flex items-center h-[72px] px-5"
  >
    <!-- Mobile: Menu button -->
    <Button variant="plain" @click="menuOpen = true" stylingclasses="md:hidden">
      Menu
    </Button>

    <!-- Desktop: nav links -->
    <nav class="hidden md:flex items-center gap-8">
      <Button
        variant="plain"
        @click="shopOpen = !shopOpen"
        stylingclasses="flex items-center gap-1"
      >
        Shop
        <span
          class="text-xs transition-transform duration-200"
          :class="shopOpen ? 'rotate-180' : ''">∨</span
        >
      </Button>
      <Link href="/showroom">Showroom</Link>
      <Link href="/about">Om os</Link>
    </nav>

    <!-- Center: logo -->
    <a href="/" class="absolute left-1/2 -translate-x-1/2">
      <img
        src="https://placehold.co/40x40"
        alt="Tusindfryd"
        class="h-8 w-auto"
      />
    </a>

    <!-- Mobile: Søg + Kurv -->
    <div class="md:hidden ml-auto flex items-center gap-5">
      <Button variant="plain">Søg</Button>
      <Button variant="plain" @click="cartOpen = true">Kurv (0)</Button>
    </div>

    <!-- Desktop: utility links -->
    <nav class="hidden md:flex ml-auto items-center gap-6">
      <Button variant="textlink">Søg</Button>
      <Text teksttype="p_medium">
        <strong class="font-medium">DA</strong><span class="font-light"> / EN</span>
      </Text>
      <Link href="/bliv-medlem">Bliv Medlem</Link>
      <Button variant="textlink" @click="cartOpen = true">Kurv (0)</Button>
    </nav>
  </div>

  <!-- Mobile menu overlay -->
  <div
    x-show="menuOpen"
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition ease-in duration-200"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    class="fixed inset-0 bg-white z-50 flex flex-col md:hidden"
    style="display: none"
  >
    <!-- Menu top bar -->
    <div class="bg-black py-2.5 px-5 flex-shrink-0">
      <Text teksttype="p_xsmall" color="text-white" stylingclasses="font-light">
        Fragt og Levering er Gratis for alle medlemmer
      </Text>
    </div>
    <div
      class="relative flex items-center h-[72px] px-5 border-b border-neutral-200 flex-shrink-0"
    >
      <a href="/" class="absolute left-1/2 -translate-x-1/2">
        <img
          src="https://placehold.co/40x40"
          alt="Tusindfryd"
          class="h-8 w-auto"
        />
      </a>
      <Button
        variant="plain"
        @click="menuOpen = false"
        stylingclasses="ml-auto !text-base hover:opacity-60 transition-opacity duration-150"
        >✕</Button
      >
    </div>

    <!-- Nav links -->
    <div class="flex-1 overflow-y-auto px-5 pt-8 flex flex-col">
      <Text
        teksttype="p_xsmall"
        color="text-gray-500"
        stylingclasses="font-light uppercase tracking-widest mb-4"
      >Shop</Text>
      <Link
        href="#"
        teksttype="statement_medium"
        stylingclasses="font-medium text-black uppercase tracking-wide py-3 border-b border-neutral-100"
        >Nyheder</Link
      >
      <Link
        href="#"
        teksttype="statement_medium"
        stylingclasses="font-medium text-black uppercase tracking-wide py-3 border-b border-neutral-100 mb-1"
        >Shop alt</Link
      >
      <Link href="#" stylingclasses="py-3 border-b border-neutral-100">Sofaer</Link>
      <Link href="#" stylingclasses="py-3 border-b border-neutral-100">Stole</Link>
      <Link href="#" stylingclasses="py-3 border-b border-neutral-100">Borde</Link>
      <Link href="#" stylingclasses="py-3 border-b border-neutral-100">Lamper</Link>
      <Link href="#" stylingclasses="py-3 border-b border-neutral-100">Tæpper</Link>
      <Link href="#" stylingclasses="py-3 border-b border-neutral-100">Opbevaring</Link>
      <Link href="#" stylingclasses="py-3 border-b border-neutral-100">Tilbehør</Link>

      <Link href="/showroom" stylingclasses="py-3 border-b border-neutral-100 mt-6">Showroom</Link>
      <Link href="/about" stylingclasses="py-3 border-b border-neutral-100">Om os</Link>
      <Link href="/bliv-medlem" stylingclasses="py-3 border-b border-neutral-100">Bliv Medlem</Link>
    </div>

    <!-- Bottom: Søg + sprog -->
    <div
      class="px-5 py-6 flex items-center justify-between flex-shrink-0 border-t border-neutral-100"
    >
      <Button variant="plain">Søg</Button>
      <Text teksttype="p_medium">
        <strong class="font-medium">DA</strong><span class="font-light"> / EN</span>
      </Text>
    </div>
  </div>

  <!-- Backdrop (desktop: shop + cart / mobil: kun cart) -->
  <div
    x-show="shopOpen || cartOpen"
    @click="shopOpen = false; cartOpen = false"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    class="fixed inset-0 top-[108px] bg-black/20 z-30"
  >
  </div>

  <!-- Shop dropdown (desktop only) -->
  <div
    x-show="shopOpen"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 -translate-y-1"
    x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100 translate-y-0"
    x-transition:leave-end="opacity-0 -translate-y-1"
    class="fixed top-[108px] left-0 w-[430px] h-[calc(100vh-108px)] bg-white z-40 flex-col border-r border-neutral-200 hidden md:flex"
  >
    <!-- Links -->
    <div class="flex flex-col flex-1 px-5 pt-6 overflow-y-auto">
      <Link
        href="#"
        teksttype="statement_medium"
        stylingclasses="font-medium text-black uppercase tracking-wide py-1"
        >Nyheder</Link
      >
      <Link
        href="#"
        teksttype="statement_medium"
        stylingclasses="font-medium text-black uppercase tracking-wide py-1 mb-5"
        >Shop alt</Link
      >
      <Link href="#" stylingclasses="py-1">Sofaer</Link>
      <Link href="#" stylingclasses="py-1">Stole</Link>
      <Link href="#" stylingclasses="py-1">Borde</Link>
      <Link href="#" stylingclasses="py-1">Lamper</Link>
      <Link href="#" stylingclasses="py-1">Tæpper</Link>
      <Link href="#" stylingclasses="py-1">Opbevaring</Link>
      <Link href="#" stylingclasses="py-1">Tilbehør</Link>
    </div>

    <!-- Featured image -->
    <div class="relative h-[220px] flex-shrink-0 overflow-hidden">
      <img
        src="https://placehold.co/430x220"
        alt="Featured kategori"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 flex justify-center items-center">
        <Text
          teksttype="p_medium"
          color="text-white"
          stylingclasses="py-0.5 border-b border-white"
          >Shop cutlery</Text
        >
      </div>
    </div>
  </div>

  <!-- Kurv panel -->
  <div
    x-show="cartOpen"
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="translate-x-full"
    x-transition:enter-end="translate-x-0"
    x-transition:leave="transition ease-in duration-200"
    x-transition:leave-start="translate-x-0"
    x-transition:leave-end="translate-x-full"
    class="fixed top-0 right-0 w-full md:w-[420px] h-full bg-white z-50 flex flex-col border-l border-neutral-200"
  >
    <div
      class="flex justify-between items-center px-5 h-[72px] border-b border-neutral-200 flex-shrink-0"
    >
      <Text teksttype="p_large" stylingclasses="uppercase tracking-wide">Din Kurv (0)</Text>
      <Button
        variant="plain"
        @click="cartOpen = false"
        stylingclasses="!text-base hover:opacity-60 transition-opacity duration-150"
        >✕</Button
      >
    </div>
    <div class="flex-1 flex items-center justify-center p-5">
      <Text teksttype="p_large" color="text-gray-500">Din kurv er tom.</Text>
    </div>
    <div class="p-5 border-t border-neutral-200 flex-shrink-0">
      <Button variant="primary">GÅ TIL KASSE</Button>
    </div>
  </div>
</header>
