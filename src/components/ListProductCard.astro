---
import Heading from "./Heading.astro";
import Text from "./Text.astro";

interface Props {
  id: number;
  title: string;
  subtitle: string;
  regular_price: number;
  member_price: number;
  image1: string | null;
}

const { id, title, subtitle, regular_price, member_price, image1 } =
  Astro.props;

function formatPrice(price: number) {
  return price.toLocaleString("da-DK") + " DKK";
}
---

<a href={`/product/${id}`} class="block group">
  <div class="relative overflow-hidden">
    <img
      src={image1 ?? "https://placehold.co/600x600/f5f5f5/999999"}
      alt={title}
      class="w-full aspect-square object-cover group-hover:scale-[1.02] transition-transform duration-300"
    />
    {
      member_price && (
        <div class="absolute bottom-0 right-0 bg-gray-100 px-2 py-1.5">
          <Text teksttype="price_small">
            MEDLEMSPRIS {formatPrice(member_price)}
          </Text>
        </div>
      )
    }
  </div>
  <div class="mt-2 flex justify-between items-baseline gap-2">
    <Heading htmlheading="h3" type="h3" stylingclasses="uppercase">
      {title}
    </Heading>
    <Text teksttype="price_small" stylingclasses="shrink-0">
      {formatPrice(regular_price)}
    </Text>
  </div>
  <Text teksttype="p_medium">{subtitle}</Text>
</a>
