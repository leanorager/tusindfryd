---
import MainLayout from "../../layouts/MainLayout.astro";
import Heading from "../../components/Heading.astro";
import Text from "../../components/Text.astro";
import Button from "../../components/Button.astro";
import ProductCardCarousel from "../../components/ProductCardCarousel.astro";

const SUPABASE_URL = "https://txfouhhxrpcyrsvjnnpd.supabase.co/rest/v1";
const SUPABASE_KEY =
  "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InR4Zm91aGh4cnBjeXJzdmpubnBkIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzgzNjc2MTcsImV4cCI6MjA5Mzk0MzYxN30.SdHA98ZoF-4DMTXeZc59-jpHjD4rnFdqcuQw-MqmpQI";

export async function getStaticPaths() {
  const res = await fetch(
    "https://txfouhhxrpcyrsvjnnpd.supabase.co/rest/v1/products?select=id",
    {
      headers: {
        apikey:
          "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InR4Zm91aGh4cnBjeXJzdmpubnBkIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzgzNjc2MTcsImV4cCI6MjA5Mzk0MzYxN30.SdHA98ZoF-4DMTXeZc59-jpHjD4rnFdqcuQw-MqmpQI",
        Authorization:
          "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InR4Zm91aGh4cnBjeXJzdmpubnBkIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzgzNjc2MTcsImV4cCI6MjA5Mzk0MzYxN30.SdHA98ZoF-4DMTXeZc59-jpHjD4rnFdqcuQw-MqmpQI",
      },
    },
  );
  const products: { id: number }[] = await res.json();
  return products.map((p) => ({ params: { id: String(p.id) } }));
}

const { id } = Astro.params;

const res = await fetch(`${SUPABASE_URL}/products?id=eq.${id}&select=*`, {
  headers: {
    apikey: SUPABASE_KEY,
    Authorization: `Bearer ${SUPABASE_KEY}`,
  },
});

type Product = {
  id: number;
  title: string;
  subtitle: string;
  regular_price: number;
  member_price: number | null;
  description: string | null;
  measurement: string | null;
  materials: string | null;
  signs_of_use: string | null;
  image1: string | null;
  image2: string | null;
  image3: string | null;
  image4: string | null;
  image5: string | null;
  image6: string | null;
  category: string[] | null;
};

const [product]: Product[] = await res.json();

function formatPrice(price: number) {
  return new Intl.NumberFormat("da-DK").format(price) + " DKK";
}

const images = [
  product.image1,
  product.image2,
  product.image3,
  product.image4,
  product.image5,
  product.image6,
].filter(Boolean) as string[];
---

<MainLayout title={`${product.title} – Tusindfryd`}>
  <main class="pb-3xl md:pb-0">
    <!-- MOBIL: skjult på desktop -->
    <div class="md:hidden">
      <div
        id="mobile-scroll"
        class="flex overflow-x-auto snap-x snap-mandatory scrollbar-hide"
      >
        {
          images.map((img, i) => (
            <div id={`mobile-img-${i}`} class="w-full flex-shrink-0 snap-start">
              <img
                src={img}
                alt={product.title}
                class="w-full aspect-[4/5] object-cover"
              />
            </div>
          ))
        }
      </div>

      <div class="px-container-mobile pt-s">
        <Heading htmlheading="h1" type="h1_small" stylingclasses="mb-xs">
          {product.title}
        </Heading>
        <Heading htmlheading="h2" type="h2_small" stylingclasses="mb-s">
          {product.subtitle}
        </Heading>

        {
          product.member_price && (
            <div class="inline-block mb-3xs -ml-[10px]">
              <Text
                teksttype="price_large"
                stylingclasses="bg-gray-100 px-2 py-1.5"
              >
                Medlemspris {formatPrice(product.member_price)}
              </Text>
            </div>
          )
        }
        <Text teksttype="price_large" stylingclasses="mb-l">
          {formatPrice(product.regular_price)}
        </Text>

        {
          images.length > 1 && (
            <div class="flex flex-wrap gap-2xs mb-2xl">
              {images.map((img, i) => (
                <button
                  class="mobile-thumb relative w-[70px] h-[100px] overflow-hidden flex-shrink-0 cursor-pointer"
                  data-index={i}
                >
                  <img
                    src={img}
                    alt={`${product.title} billede ${i + 1}`}
                    class="w-full h-full object-cover"
                  />
                  <div class="absolute inset-0 bg-black/20 pointer-events-none" />
                </button>
              ))}
            </div>
          )
        }

        <div x-data="{ open: null }" class="border-t border-neutral-200">
          <div class="border-b border-neutral-200">
            <button
              @click="open = open === 'om' ? null : 'om'"
              class="w-full flex justify-between items-center py-s cursor-pointer"
            >
              <Heading htmlheading="h3" type="h3">Om produktet</Heading>
              <span
                class="text-xs transition-transform duration-200"
                :class="open === 'om' ? 'rotate-180' : ''">∨</span
              >
            </button>
            <div x-show="open === 'om'" x-transition style="display:none">
              <Text teksttype="p_xsmall" stylingclasses="pb-container"
                >{product.description}</Text
              >
            </div>
          </div>
          <div class="border-b border-neutral-200">
            <button
              @click="open = open === 'maal' ? null : 'maal'"
              class="w-full flex justify-between items-center py-s cursor-pointer"
            >
              <Heading htmlheading="h3" type="h3">Mål & Materialer</Heading>
              <span
                class="text-xs transition-transform duration-200"
                :class="open === 'maal' ? 'rotate-180' : ''">∨</span
              >
            </button>
            <div x-show="open === 'maal'" x-transition style="display:none">
              <Text
                teksttype="p_xsmall"
                stylingclasses="pb-2 whitespace-pre-line"
                >{product.measurement}</Text
              >
              <Text teksttype="p_xsmall" stylingclasses="pb-container"
                >{product.materials}</Text
              >
            </div>
          </div>
          <div class="border-b border-neutral-200">
            <button
              @click="open = open === 'brug' ? null : 'brug'"
              class="w-full flex justify-between items-center py-s cursor-pointer"
            >
              <Heading htmlheading="h3" type="h3">Brugsspor</Heading>
              <span
                class="text-xs transition-transform duration-200"
                :class="open === 'brug' ? 'rotate-180' : ''">∨</span
              >
            </button>
            <div x-show="open === 'brug'" x-transition style="display:none">
              <Text teksttype="p_xsmall" stylingclasses="pb-container"
                >{product.signs_of_use}</Text
              >
            </div>
          </div>
        </div>

        <div class="mt-xl mb-s">
          <Heading htmlheading="h3" type="h3" stylingclasses="mb-xs"
            >Medlemsfordele</Heading
          >
          <Text
            teksttype="p_xsmall"
            color="text-gray-500"
            stylingclasses="mb-2xs">10% rabat på alle varer</Text
          >
          <Text
            teksttype="p_xsmall"
            color="text-gray-500"
            stylingclasses="mb-2xs">Gratis fragt og levering</Text
          >
          <Text
            teksttype="p_xsmall"
            color="text-gray-500"
            stylingclasses="mb-2xs">Pre-access til de nyeste drops</Text
          >
          <Text
            teksttype="p_xsmall"
            color="text-gray-500"
            stylingclasses="mb-2xs">Levering indenfor 1–3 dage*</Text
          >
          <Text teksttype="p_xsmall" color="text-gray-500">
            <a href="/#" class="underline cursor-pointer">For virksomheder</a>
          </Text>
        </div>

        <div
          x-data
          class="sticky bottom-0 z-40 -mx-[10px] bg-white px-container-mobile pb-container-mobile pt-container-mobile border-t border-neutral-100"
        >
          <Button
            variant="secondary"
            href="/bliv-medlem"
            stylingclasses="block w-full text-center mb-xs"
          >
            Bliv Medlem
          </Button>
          <Button
            variant="primary"
            stylingclasses="flex justify-between items-center px-container"
            @click={`$store.cart.add({ id: ${product.id}, title: ${JSON.stringify(product.title)}, subtitle: ${JSON.stringify(product.subtitle)}, price: ${product.regular_price}, image: ${JSON.stringify(product.image1 ?? "")} })`}
          >
            <span>Tilføj til kurv</span>
            <span>{formatPrice(product.regular_price)}</span>
          </Button>
        </div>
      </div>
    </div>

    <!-- DESKTOP: skjult på mobil -->
    <!-- DESKTOP / TABLET -->
    <div
      class="hidden md:grid md:grid-cols-2 lg:grid-cols-12 gap-2xs mx-container"
    >
      <!-- Venstre kolonne: KUN på desktop (lg+) -->
      <div
        class="hidden lg:block lg:col-span-3 sticky self-start pr-m lg:pt-[100px]"
        style="top: var(--header-h, 78px)"
      >
        <nav class="flex items-center gap-container-mobile mb-xs">
          <Text teksttype="p_medium" color="text-gray-400">
            <a href="/shop/alt" class="hover:text-gray-600 transition-colors"
              >Shop Alt</a
            >
          </Text>
          <span class="bc-sep hidden h-[13px] w-px bg-gray-300 self-center"
          ></span>
          <a
            class="bc-cat hidden font-helv font-normal text-[14px] text-gray-400 hover:text-gray-600 transition-colors"
            href="#"></a>
        </nav>
        <Heading htmlheading="h1" type="h1_small" stylingclasses="mb-xs"
          >{product.title}</Heading
        >
        <Heading htmlheading="h2" type="h2_small" stylingclasses="mb-l"
          >{product.subtitle}</Heading
        >
        {
          product.member_price && (
            <div class="inline-block mb-1 -ml-container">
              <Text
                teksttype="price_large"
                stylingclasses="bg-gray-100 px-container py-2xs"
              >
                Medlemspris {formatPrice(product.member_price)}
              </Text>
            </div>
          )
        }
        <Text teksttype="price_large">{formatPrice(product.regular_price)}</Text
        >

        {
          images.length > 1 && (
            <div class="flex flex-wrap gap-2xs mt-l mb-5xl">
              {images.map((img, i) => (
                <button
                  class="desktop-thumb relative w-[70px] h-[100px] overflow-hidden flex-shrink-0 cursor-pointer"
                  data-index={i}
                >
                  <img
                    src={img}
                    alt={`${product.title} billede ${i + 1}`}
                    class="w-full h-full object-cover"
                  />
                  <div class="absolute inset-0 bg-black/20 pointer-events-none" />
                </button>
              ))}
            </div>
          )
        }
      </div>

      <!-- Billeder: halv bredde på tablet, 6 col på desktop -->
      <div class="md:col-span-1 lg:col-span-6 flex flex-col gap-2xs">
        {
          images.map((img, i) => (
            <img
              id={`desktop-img-${i}`}
              src={img}
              alt={product.title}
              class="w-full aspect-[4/5] object-cover desktop-product-img"
            />
          ))
        }
      </div>

      <!-- Højre kolonne: al info på tablet / kun accordion+knapper på desktop -->
      <div
        class="md:col-span-1 lg:col-span-3 sticky self-start md:pl-container lg:pl-m lg:pr-0 md:pt-container lg:pt-[100px]"
        style="top: var(--header-h, 78px)"
      >
        <!-- Kun på tablet: breadcrumb + titel + pris -->
        <div class="lg:hidden mb-l">
          <nav class="flex items-center gap-container-mobile mb-xs">
            <Text teksttype="p_medium" color="text-gray-400">
              <a href="/shop/alt" class="hover:text-gray-600 transition-colors"
                >Shop Alt</a
              >
            </Text>
            <span class="bc-sep hidden h-[13px] w-px bg-gray-300 self-center"
            ></span>
            <a
              class="bc-cat hidden font-helv font-normal text-[14px] text-gray-400 hover:text-gray-600 transition-colors"
              href="#"></a>
          </nav>
          <Heading htmlheading="h1" type="h1_small" stylingclasses="mb-xs"
            >{product.title}</Heading
          >
          <Heading htmlheading="h2" type="h2_small" stylingclasses="mb-l"
            >{product.subtitle}</Heading
          >
          {
            product.member_price && (
              <div class="inline-block mb-1">
                <Text
                  teksttype="price_large"
                  stylingclasses="bg-gray-100 px-2 py-2xs -ml-container-mobile"
                >
                  Medlemspris {formatPrice(product.member_price)}
                </Text>
              </div>
            )
          }
          <Text teksttype="price_large" stylingclasses="mb-0"
            >{formatPrice(product.regular_price)}</Text
          >
        </div>

        <!-- Altid: accordion -->
        <div x-data="{ open: null }" class="border-t border-neutral-200">
          <div class="border-b border-neutral-200">
            <button
              @click="open = open === 'om' ? null : 'om'"
              class="w-full flex justify-between items-center py-s cursor-pointer"
            >
              <Heading htmlheading="h3" type="h3">Om produktet</Heading>
              <span
                class="text-xs transition-transform duration-200"
                :class="open === 'om' ? 'rotate-180' : ''">∨</span
              >
            </button>
            <div x-show="open === 'om'" x-transition style="display:none">
              <Text teksttype="p_xsmall" stylingclasses="pb-container"
                >{product.description}</Text
              >
            </div>
          </div>
          <div class="border-b border-neutral-200">
            <button
              @click="open = open === 'maal' ? null : 'maal'"
              class="w-full flex justify-between items-center py-s cursor-pointer"
            >
              <Heading htmlheading="h3" type="h3">Mål & Materialer</Heading>
              <span
                class="text-xs transition-transform duration-200"
                :class="open === 'maal' ? 'rotate-180' : ''">∨</span
              >
            </button>
            <div x-show="open === 'maal'" x-transition style="display:none">
              <Text
                teksttype="p_xsmall"
                stylingclasses="pb-container whitespace-pre-line"
                >{product.measurement}</Text
              >
              <Text teksttype="p_xsmall" stylingclasses="pb-container"
                >{product.materials}</Text
              >
            </div>
          </div>
          <div class="border-b border-neutral-200">
            <button
              @click="open = open === 'brug' ? null : 'brug'"
              class="w-full flex justify-between items-center py-s cursor-pointer"
            >
              <Heading htmlheading="h3" type="h3">Brugsspor</Heading>
              <span
                class="text-xs transition-transform duration-200"
                :class="open === 'brug' ? 'rotate-180' : ''">∨</span
              >
            </button>
            <div x-show="open === 'brug'" x-transition style="display:none">
              <Text teksttype="p_xsmall" stylingclasses="pb-container"
                >{product.signs_of_use}</Text
              >
            </div>
          </div>
        </div>

        <!-- Altid: Medlemsfordele -->
        <div class="mt-xl mb-xl">
          <Heading htmlheading="h3" type="h3" stylingclasses="mb-xs"
            >Medlemsfordele</Heading
          >
          <Text
            teksttype="p_xsmall"
            color="text-gray-500"
            stylingclasses="mb-2xs">10% rabat på alle varer</Text
          >
          <Text
            teksttype="p_xsmall"
            color="text-gray-500"
            stylingclasses="mb-2xs">Gratis fragt og levering</Text
          >
          <Text
            teksttype="p_xsmall"
            color="text-gray-500"
            stylingclasses="mb-2xs">Pre-access til de nyeste drops</Text
          >
          <Text
            teksttype="p_xsmall"
            color="text-gray-500"
            stylingclasses="mb-2xs">Levering indenfor 1–3 dage*</Text
          >
          <Text teksttype="p_xsmall" color="text-gray-500">
            <a href="/bliv-medlem" class="underline cursor-pointer"
              >For virksomheder</a
            >
          </Text>
        </div>

        <!-- Altid: knapper -->
        <div x-data>
          <Button
            variant="secondary"
            href="/bliv-medlem"
            stylingclasses="block w-full text-center mb-xs"
          >
            Bliv Medlem
          </Button>
          <Button
            variant="primary"
            stylingclasses="flex justify-between items-center px-container mb-5xl"
            @click={`$store.cart.add({ id: ${product.id}, title: ${JSON.stringify(product.title)}, subtitle: ${JSON.stringify(product.subtitle)}, price: ${product.regular_price}, image: ${JSON.stringify(product.image1 ?? "")} })`}
          >
            <span>Tilføj til kurv</span>
            <span>{formatPrice(product.regular_price)}</span>
          </Button>
        </div>
      </div>
    </div>
    <ProductCardCarousel
      title="Relaterede produkter"
      category={product.category?.find((c) => c !== "Ny") ??
        product.category?.[0]}
      excludeId={product.id}
      limit={8}
    />
  </main>

  <style>
    @media (min-width: 1280px) {
      .desktop-product-img {
        aspect-ratio: auto;
        height: calc(100vh - var(--header-h, 78px));
      }
    }
  </style>

  <script>
    const headerH = document.querySelector("header")?.offsetHeight ?? 78;
    document.documentElement.style.setProperty("--header-h", `${headerH}px`);

    document
      .querySelectorAll<HTMLButtonElement>(".desktop-thumb")
      .forEach((btn) => {
        btn.addEventListener("click", () => {
          const index = btn.dataset.index;
          const img = document.getElementById(`desktop-img-${index}`);
          if (img) {
            const h = document.querySelector("header")?.offsetHeight ?? 0;
            const top = img.getBoundingClientRect().top + window.scrollY - h;
            window.scrollTo({ top, behavior: "smooth" });
          }
        });
      });

    document
      .querySelectorAll<HTMLButtonElement>(".mobile-thumb")
      .forEach((btn) => {
        btn.addEventListener("click", () => {
          const index = parseInt(btn.dataset.index ?? "0");
          const scroll = document.getElementById("mobile-scroll");
          if (scroll)
            scroll.scrollTo({
              left: scroll.offsetWidth * index,
              behavior: "smooth",
            });
        });
      });
  </script>

  <script>
    try {
      const ref = document.referrer;
      if (ref) {
        const parts = new URL(ref).pathname.split("/").filter(Boolean);
        if (parts[0] === "shop" && parts[1] && parts[1] !== "alt") {
          const slug = parts[1];
          const names: { [key: string]: string } = {
            stole: "Stole",
            sofaer: "Sofaer",
            borde: "Borde",
            lamper: "Lamper",
            taeppe: "Tæpper",
            opbevaring: "Opbevaring",
            andet: "Andet",
            nyheder: "Nyheder",
          };
          const name =
            names[slug] ?? slug.charAt(0).toUpperCase() + slug.slice(1);
          document
            .querySelectorAll(".bc-sep")
            .forEach((el) => el.classList.remove("hidden"));
          document.querySelectorAll(".bc-cat").forEach((el) => {
            (el as HTMLAnchorElement).href = `/shop/${slug}`;
            el.textContent = name;
            el.classList.remove("hidden");
          });
        }
      }
    } catch (e) {}
  </script>
</MainLayout>
