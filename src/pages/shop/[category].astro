---
import MainLayout from "../../layouts/MainLayout.astro";
import Heading from "../../components/Heading.astro";
import Text from "../../components/Text.astro";
import ListProductCard from "../../components/ListProductCard.astro";
import { CATEGORIES } from "../../lib/categories";
import type { CategoryConfig } from "../../lib/categories";

const SUPABASE_URL = "https://txfouhhxrpcyrsvjnnpd.supabase.co/rest/v1";
const SUPABASE_KEY =
  "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InR4Zm91aGh4cnBjeXJzdmpubnBkIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzgzNjc2MTcsImV4cCI6MjA5Mzk0MzYxN30.SdHA98ZoF-4DMTXeZc59-jpHjD4rnFdqcuQw-MqmpQI";

const PAGE_SIZE = 24;
const MAX_PRICE = 30000;

export async function getStaticPaths() {
  return CATEGORIES.map((cat) => ({
    params: { category: cat.slug },
    props: { categoryConfig: cat },
  }));
}

interface Props {
  categoryConfig: CategoryConfig;
}

const { categoryConfig } = Astro.props;

let baseUrl = `${SUPABASE_URL}/products?select=id,title,subtitle,regular_price,member_price,image1,image2`;
if (categoryConfig.filter) {
  baseUrl += `&category=cs.${encodeURIComponent(`["${categoryConfig.filter}"]`)}`;
}

const response = await fetch(baseUrl, {
  headers: {
    apikey: SUPABASE_KEY,
    Authorization: `Bearer ${SUPABASE_KEY}`,
    Prefer: "count=exact",
    Range: `0-${PAGE_SIZE - 1}`,
  },
});

const contentRange = response.headers.get("content-range");
const totalCount = contentRange ? parseInt(contentRange.split("/")[1]) || 0 : 0;

type Product = {
  id: number;
  title: string;
  subtitle: string;
  regular_price: number;
  member_price: number;
  image1: string | null;
  image2: string | null;
};

const products: Product[] = await response.json();
const initialShown = products.length;

const VALID_CAT_VALUES = [
  "Sofa",
  "Stol",
  "Bord",
  "Lampe",
  "Tæppe",
  "Opbevaring",
  "Andet",
];
const initialCategories =
  categoryConfig.filter && VALID_CAT_VALUES.includes(categoryConfig.filter)
    ? [categoryConfig.filter]
    : [];
---

<MainLayout title={`${categoryConfig.title} – Tusindfryd`}>
  <div x-data="filterPanel">
    <!-- Backdrop -->
    <div
      x-show="panelOpen"
      @click="panelOpen = false"
      x-transition:enter="transition ease-out duration-200"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      x-transition:leave="transition ease-in duration-150"
      x-transition:leave-start="opacity-100"
      x-transition:leave-end="opacity-0"
      class="fixed inset-0 bg-black/30 z-40"
      style="display:none"
    >
    </div>

    <!-- Filter panel -->
    <div
      x-show="panelOpen"
      x-transition:enter="transition ease-out duration-300"
      x-transition:enter-start="translate-x-full"
      x-transition:enter-end="translate-x-0"
      x-transition:leave="transition ease-in duration-200"
      x-transition:leave-start="translate-x-0"
      x-transition:leave-end="translate-x-full"
      class="fixed top-0 right-0 h-full w-full md:w-[420px] bg-white z-50 flex flex-col"
      style="display:none"
      @keydown.escape.window="panelOpen = false"
    >
      <!-- Panel header -->
      <div
        class="flex justify-between items-center px-m pt-m pb-s flex-shrink-0"
      >
        <span class="font-helv font-normal text-[14px]">Filter</span>
        <button
          @click="panelOpen = false"
          class="w-8 h-8 flex items-center justify-center font-helv text-[18px] leading-none hover:opacity-60 transition-opacity cursor-pointer"
          >✕</button
        >
      </div>

      <!-- Active chips -->
      <div class="px-m flex flex-wrap gap-xs flex-shrink-0 min-h-[10px] mb-3">
        <template x-if="sort">
          <button
            @click="sort = null; scheduleCountUpdate()"
            class="flex items-center gap-1.5 border border-neutral-300 bg-neutral-50 px-3 py-1.5 font-helv font-normal text-[12px] hover:bg-neutral-100 transition-colors cursor-pointer"
          >
            <span class="text-[10px]">✕</span>
            <span x-text="sortOptions.find(o => o.value === sort)?.label"
            ></span>
          </button>
        </template>
        <template x-for="cat in categories" :key="'cat-' + cat">
          <button
            @click="toggleCategory(cat)"
            class="flex items-center gap-1.5 border border-neutral-300 bg-neutral-50 px-3 py-1.5 font-helv font-normal text-[12px] hover:bg-neutral-100 transition-colors cursor-pointer"
          >
            <span class="text-[10px]">✕</span>
            <span
              x-text="categoryOptions.find(c => c.value === cat)?.label || cat"
            ></span>
          </button>
        </template>
        <template x-for="mat in materials" :key="'mat-' + mat">
          <button
            @click="toggleMaterial(mat)"
            class="flex items-center gap-1.5 border border-neutral-300 bg-neutral-50 px-3 py-1.5 font-helv font-normal text-[12px] hover:bg-neutral-100 transition-colors cursor-pointer"
          >
            <span class="text-[10px]">✕</span>
            <span x-text="mat"></span>
          </button>
        </template>
        <template x-for="col in colors" :key="'col-' + col">
          <button
            @click="toggleColor(col)"
            class="flex items-center gap-1.5 border border-neutral-300 bg-neutral-50 px-3 py-1.5 font-helv font-normal text-[12px] hover:bg-neutral-100 transition-colors cursor-pointer"
          >
            <span class="text-[10px]">✕</span>
            <span x-text="col"></span>
          </button>
        </template>
        <template x-if="minPrice > 0 || maxPrice < MAX_PRICE_VAL">
          <button
            @click="minPrice = 0; maxPrice = MAX_PRICE_VAL; scheduleCountUpdate()"
            class="flex items-center gap-1.5 border border-neutral-300 bg-neutral-50 px-3 py-1.5 font-helv font-normal text-[12px] hover:bg-neutral-100 transition-colors cursor-pointer"
          >
            <span class="text-[10px]">✕</span>
            <span
              x-text="'DKK ' + formatNum(minPrice) + '–' + formatNum(maxPrice)"
            ></span>
          </button>
        </template>
      </div>

      <!-- Scrollable content -->
      <div class="flex-1 overflow-y-auto">
        <div class="px-m">
          <!-- Sort section -->
          <div class="mb-container mt-2xs">
            <p class="font-helv font-normal text-[13px] text-neutral-400 mb-s">
              Sorter efter
            </p>
            <template x-for="option in sortOptions" :key="option.value">
              <label
                class="flex items-center gap-3 mb-3 cursor-pointer select-none"
              >
                <span
                  class="w-[18px] h-[18px] border flex-shrink-0 flex items-center justify-center transition-colors duration-150"
                  :class="sort === option.value ? 'border-black bg-black' : 'border-neutral-300'"
                  @click="sort = (sort === option.value ? null : option.value); scheduleCountUpdate()"
                >
                  <svg
                    x-show="sort === option.value"
                    class="w-[10px] h-[10px]"
                    fill="none"
                    viewBox="0 0 10 10"
                    style="display:none"
                  >
                    <path
                      d="M1.5 5l2.5 2.5 5-5"
                      stroke="white"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"></path>
                  </svg>
                </span>
                <span
                  class="font-helv font-normal text-[13px]"
                  x-text="option.label"></span>
              </label>
            </template>
          </div>

          <hr class="border-neutral-200" />

          <!-- Kategori accordion -->
          <div class="border-b border-neutral-200">
            <button
              @click="catOpen = !catOpen"
              class="w-full flex justify-between items-center py-4 cursor-pointer"
            >
              <span class="font-helv font-normal text-[13px]">Kategori</span>
              <img
                src="/svg/arrow-down.svg"
                alt=""
                class="h-[6.5px] w-auto transition-transform duration-200 flex-shrink-0"
                :class="catOpen ? 'rotate-180' : ''"
              />
            </button>
            <div
              x-show="catOpen"
              x-transition
              style="display:none"
              class="pb-s"
            >
              <template x-for="cat in categoryOptions" :key="cat.value">
                <label
                  class="flex items-center gap-3 mb-3 cursor-pointer select-none"
                >
                  <span
                    class="w-[18px] h-[18px] border flex-shrink-0 flex items-center justify-center transition-colors duration-150"
                    :class="categories.includes(cat.value) ? 'border-black bg-black' : 'border-neutral-300'"
                    @click="toggleCategory(cat.value)"
                  >
                    <svg
                      x-show="categories.includes(cat.value)"
                      class="w-[10px] h-[10px]"
                      fill="none"
                      viewBox="0 0 10 10"
                      style="display:none"
                    >
                      <path
                        d="M1.5 5l2.5 2.5 5-5"
                        stroke="white"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"></path>
                    </svg>
                  </span>
                  <span
                    class="font-helv font-normal text-[13px]"
                    x-text="cat.label"></span>
                </label>
              </template>
            </div>
          </div>

          <!-- Materiale accordion -->
          <div class="border-b border-neutral-200">
            <button
              @click="matOpen = !matOpen"
              class="w-full flex justify-between items-center py-4 cursor-pointer"
            >
              <span class="font-helv font-normal text-[13px]">Matriale</span>
              <img
                src="/svg/arrow-down.svg"
                alt=""
                class="h-[6.5px] w-auto transition-transform duration-200 flex-shrink-0"
                :class="matOpen ? 'rotate-180' : ''"
              />
            </button>
            <div
              x-show="matOpen"
              x-transition
              style="display:none"
              class="pb-s"
            >
              <template x-for="mat in materialOptions" :key="mat">
                <label
                  class="flex items-center gap-3 mb-3 cursor-pointer select-none"
                >
                  <span
                    class="w-[18px] h-[18px] border flex-shrink-0 flex items-center justify-center transition-colors duration-150"
                    :class="materials.includes(mat) ? 'border-black bg-black' : 'border-neutral-300'"
                    @click="toggleMaterial(mat)"
                  >
                    <svg
                      x-show="materials.includes(mat)"
                      class="w-[10px] h-[10px]"
                      fill="none"
                      viewBox="0 0 10 10"
                      style="display:none"
                    >
                      <path
                        d="M1.5 5l2.5 2.5 5-5"
                        stroke="white"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"></path>
                    </svg>
                  </span>
                  <span class="font-helv font-normal text-[13px]" x-text="mat"
                  ></span>
                </label>
              </template>
            </div>
          </div>

          <!-- Farve accordion -->
          <div class="border-b border-neutral-200">
            <button
              @click="colOpen = !colOpen"
              class="w-full flex justify-between items-center py-4 cursor-pointer"
            >
              <span class="font-helv font-normal text-[13px]">Farve</span>
              <img
                src="/svg/arrow-down.svg"
                alt=""
                class="h-[6.5px] w-auto transition-transform duration-200 flex-shrink-0"
                :class="colOpen ? 'rotate-180' : ''"
              />
            </button>
            <div
              x-show="colOpen"
              x-transition
              style="display:none"
              class="pb-s"
            >
              <template x-for="col in colorOptions" :key="col">
                <label
                  class="flex items-center gap-3 mb-3 cursor-pointer select-none"
                >
                  <span
                    class="w-[18px] h-[18px] border flex-shrink-0 flex items-center justify-center transition-colors duration-150"
                    :class="colors.includes(col) ? 'border-black bg-black' : 'border-neutral-300'"
                    @click="toggleColor(col)"
                  >
                    <svg
                      x-show="colors.includes(col)"
                      class="w-[10px] h-[10px]"
                      fill="none"
                      viewBox="0 0 10 10"
                      style="display:none"
                    >
                      <path
                        d="M1.5 5l2.5 2.5 5-5"
                        stroke="white"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"></path>
                    </svg>
                  </span>
                  <span class="font-helv font-normal text-[13px]" x-text="col"
                  ></span>
                </label>
              </template>
            </div>
          </div>

          <!-- Pris accordion -->
          <div class="border-b border-neutral-200">
            <button
              @click="priceOpen = !priceOpen"
              class="w-full flex justify-between items-center py-4 cursor-pointer"
            >
              <span class="font-helv font-normal text-[13px]">Pris</span>
              <img
                src="/svg/arrow-down.svg"
                alt=""
                class="h-[6.5px] w-auto transition-transform duration-200 flex-shrink-0"
                :class="priceOpen ? 'rotate-180' : ''"
              />
            </button>
            <div
              x-show="priceOpen"
              x-transition
              style="display:none"
              class="pb-m"
            >
              <!-- Dual range slider -->
              <div class="relative mt-l mb-xs range-wrap">
                <!-- Track background -->
                <div
                  class="absolute inset-x-0 h-[1px] bg-neutral-200 top-1/2 -translate-y-1/2 pointer-events-none"
                >
                </div>
                <!-- Track fill -->
                <div
                  class="absolute h-[1px] bg-black top-1/2 -translate-y-1/2 pointer-events-none"
                  :style="`left: ${(minPrice/MAX_PRICE_VAL)*100}%; right: ${100-(maxPrice/MAX_PRICE_VAL)*100}%`"
                >
                </div>
                <!-- Min input -->
                <input
                  type="range"
                  min="0"
                  :max="MAX_PRICE_VAL"
                  step="500"
                  :value="minPrice"
                  @input="setMinPrice(+$event.target.value)"
                  class="range-input"
                  :style="`z-index: ${minPrice >= maxPrice - 500 ? 5 : 3}`"
                />
                <!-- Max input -->
                <input
                  type="range"
                  min="0"
                  :max="MAX_PRICE_VAL"
                  step="500"
                  :value="maxPrice"
                  @input="setMaxPrice(+$event.target.value)"
                  class="range-input"
                  style="z-index: 4"
                />
              </div>
              <!-- Thumb position labels -->
              <div class="relative h-5 mb-s">
                <span
                  class="absolute font-helv font-normal text-[11px] whitespace-nowrap pointer-events-none"
                  :style="`left: clamp(0%, ${(minPrice/MAX_PRICE_VAL)*100}%, 100%); transform: translateX(${(maxPrice - minPrice) / MAX_PRICE_VAL < 0.2 ? '-100%' : '-50%'})`"
                  x-text="formatNum(minPrice) + ' DKK'"></span>
                <span
                  class="absolute font-helv font-normal text-[11px] whitespace-nowrap pointer-events-none"
                  :style="`left: clamp(0%, ${(maxPrice/MAX_PRICE_VAL)*100}%, 100%); transform: translateX(${(maxPrice - minPrice) / MAX_PRICE_VAL < 0.2 ? '0%' : (maxPrice/MAX_PRICE_VAL > 0.85 ? '-100%' : '-50%')})`"
                  x-text="formatNum(maxPrice) + ' DKK'"></span>
              </div>
              <!-- Price text inputs -->
              <div class="flex gap-xs">
                <div
                  class="flex-1 border border-black flex items-center px-3 py-1.5 gap-xs"
                >
                  <input
                    type="text"
                    inputmode="numeric"
                    :value="formatNum(minPrice)"
                    @change="setMinPrice(parseInputNum($event.target.value)); $event.target.value = formatNum(minPrice)"
                    class="flex-1 w-0 min-w-0 font-helv font-normal text-[13px] outline-none border-0 ring-0"
                  />
                  <span
                    class="font-helv font-normal text-[13px] text-neutral-500 flex-shrink-0"
                    >DKK</span
                  >
                </div>
                <div
                  class="flex-1 border border-black flex items-center px-3 py-1.5 gap-xs"
                >
                  <input
                    type="text"
                    inputmode="numeric"
                    :value="formatNum(maxPrice)"
                    @change="setMaxPrice(parseInputNum($event.target.value)); $event.target.value = formatNum(maxPrice)"
                    class="flex-1 w-0 min-w-0 font-helv font-normal text-[13px] outline-none border-0 ring-0"
                  />
                  <span
                    class="font-helv font-normal text-[13px] text-neutral-500 flex-shrink-0"
                    >DKK</span
                  >
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Footer buttons -->
      <div
        class="flex-shrink-0 border-t border-neutral-200 flex gap-3 px-s py-s"
      >
        <button
          @click="clearAll()"
          class="flex-1 border border-black font-helv font-normal text-[13px] py-s hover:bg-black hover:text-white transition-all duration-150 cursor-pointer"
        >
          Ryd alle
        </button>
        <button
          @click="applyFilters()"
          class="flex-1 bg-black text-white font-helv font-normal text-[13px] py-s hover:opacity-80 transition-opacity cursor-pointer"
        >
          <span x-show="!countLoading" x-text="'Vis (' + resultCount + ')'"
          ></span>
          <span x-show="countLoading" style="display:none"
            >Indlæser&hellip;</span
          >
        </button>
      </div>
    </div>

    <!-- Main content -->
    <main class="px-container-mobile md:px-container pt-l pb-3xl md:pt-3xl">
      <!-- Page header -->
      <div class="mb-l md:mb-3xl md:max-w-sm">
        <Heading
          htmlheading="h3"
          type="h3"
          stylingclasses="uppercase mb-container-mobile"
        >
          {categoryConfig.title}
        </Heading>
        {
          categoryConfig.description && (
            <Text teksttype="statement_small">
              {categoryConfig.description}
            </Text>
          )
        }
      </div>

      <!-- Filter bar -->
      <div class="flex justify-end mb-l md:mb-3xl">
        <button
          @click="panelOpen = true"
          class="group flex items-center gap-xs border border-black px-container py-container-mobile font-helv font-normal text-[13px] transition-all duration-150 cursor-pointer"
          :class="activeFilterCount > 0 ? 'bg-black text-white' : 'hover:bg-black hover:text-white'"
        >
          <img
            src="/svg/filter.svg"
            alt=""
            width="17px"
            height="17px"
            class="transition-all duration-150 group-hover:invert"
            :class="activeFilterCount > 0 ? 'invert' : ''"
          />
          Filtrér &amp; sortér
          <span
            x-show="activeFilterCount > 0"
            x-text="'(' + activeFilterCount + ')'"
            style="display:none"></span>
        </button>
      </div>

      <!-- Product grid -->
      {
        products.length > 0 ? (
          <div
            id="product-grid"
            class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-2xs gap-y-xl lg:gap-y-3xl"
          >
            {products.map((product) => (
              <ListProductCard
                id={product.id}
                title={product.title}
                subtitle={product.subtitle}
                regular_price={product.regular_price}
                member_price={product.member_price}
                image1={product.image1}
                image2={product.image2}
              />
            ))}
          </div>
        ) : (
          <div class="flex items-center justify-center py-4xl">
            <Text teksttype="p_medium" color="text-neutral-400">
              Ingen produkter fundet i denne kategori.
            </Text>
          </div>
        )
      }

      <!-- Pagination footer -->
      <div
        id="pagination-footer"
        class={`mt-2xl flex flex-col items-center gap-3 ${products.length === 0 ? "hidden" : ""}`}
      >
        <button
          id="load-more-btn"
          @click="loadMore()"
          class="inline-flex items-end gap-[5px] pb-[5px] border-b border-black text-black transition-opacity duration-100 hover:opacity-90 cursor-pointer"
          style={totalCount > PAGE_SIZE ? "" : "display:none"}
        >
          <Text teksttype="p_xsmall">Se flere</Text>
        </button>

        <p
          id="product-count"
          class="font-helv font-normal text-[12px] text-neutral-400"
        >
          Viser 1-{initialShown} ud af {totalCount} produkter
        </p>

        <div class="w-full max-w-xs h-[1px] bg-neutral-200 relative">
          <div
            id="progress-bar"
            class="absolute left-0 top-0 h-full bg-black transition-all duration-500"
            style={`width: ${totalCount ? (initialShown / totalCount) * 100 : 0}%`}
          >
          </div>
        </div>
      </div>
    </main>
  </div>
</MainLayout>

<style>
  .range-wrap {
    height: 20px;
    position: relative;
  }

  .range-input {
    -webkit-appearance: none;
    appearance: none;
    background: transparent;
    pointer-events: none;
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    margin: 0;
    padding: 0;
  }

  .range-input::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    pointer-events: all;
    width: 16px;
    height: 16px;
    background: white;
    border: 1px solid black;
    cursor: ew-resize;
    border-radius: 0;
  }

  .range-input::-moz-range-thumb {
    pointer-events: all;
    width: 16px;
    height: 16px;
    background: white;
    border: 1px solid black;
    cursor: ew-resize;
    border-radius: 0;
    -moz-appearance: none;
  }

  .range-input::-webkit-slider-runnable-track {
    background: transparent;
    height: 1px;
  }

  .range-input::-moz-range-track {
    background: transparent;
    height: 1px;
  }
</style>

<script
  define:vars={{
    SUPABASE_URL,
    SUPABASE_KEY,
    totalCount,
    initialShown,
    initialCategories,
    MAX_PRICE,
    PAGE_SIZE,
  }}
>
  document.addEventListener("alpine:init", () => {
    Alpine.data("filterPanel", () => {
      const SORT_OPTIONS = [
        { value: "newest", label: "Nyeste" },
        { value: "bestsellers", label: "Bestsellers" },
        { value: "price_asc", label: "Pris: Lav til høj" },
        { value: "price_desc", label: "Pris: Høj til lav" },
      ];

      const CATEGORY_OPTS = [
        { label: "Sofaer", value: "Sofa" },
        { label: "Stole", value: "Stol" },
        { label: "Borde", value: "Bord" },
        { label: "Lamper", value: "Lampe" },
        { label: "Tæpper", value: "Tæppe" },
        { label: "Opbevaring", value: "Opbevaring" },
        { label: "Andet", value: "Andet" },
      ];

      const MATERIAL_OPTS = [
        "Flet",
        "Gips",
        "Glas",
        "Keramik",
        "Læder",
        "Lærred",
        "Metal",
        "Plast",
        "Skumfyld",
        "Tekstil",
        "Træ",
        "Uld",
        "Velour",
      ];

      const COLOR_OPTS = [
        "Beige",
        "Blå",
        "Brun",
        "Grå",
        "Grøn",
        "Gul",
        "Hvid",
        "Lyserød",
        "Orange",
        "Rød",
        "Sort",
        "Sølv",
      ];

      return {
        panelOpen: false,

        sort: null,
        sortOptions: SORT_OPTIONS,
        categoryOptions: CATEGORY_OPTS,
        materialOptions: MATERIAL_OPTS,
        colorOptions: COLOR_OPTS,

        categories: [...initialCategories],
        materials: [],
        colors: [],
        minPrice: 0,
        maxPrice: MAX_PRICE,
        MAX_PRICE_VAL: MAX_PRICE,

        catOpen: false,
        matOpen: false,
        colOpen: false,
        priceOpen: false,

        resultCount: totalCount,
        offset: initialShown,
        loading: false,
        countLoading: false,
        _countTimer: null,
        _filteredProducts: [],

        init() {
          this.$watch("panelOpen", (open) => {
            document.body.style.overflow = open ? "hidden" : "";
          });
        },

        get activeFilterCount() {
          let c = 0;
          if (this.sort) c++;
          c += this.categories.length;
          c += this.materials.length;
          c += this.colors.length;
          if (this.minPrice > 0 || this.maxPrice < MAX_PRICE) c++;
          return c;
        },

        formatNum(n) {
          return new Intl.NumberFormat("da-DK").format(n);
        },

        formatPrice(n) {
          return new Intl.NumberFormat("da-DK").format(n) + " DKK";
        },

        parseInputNum(s) {
          return parseInt(String(s).replace(/\./g, "").replace(",", ".")) || 0;
        },

        toggleCategory(val) {
          const idx = this.categories.indexOf(val);
          if (idx >= 0) this.categories.splice(idx, 1);
          else this.categories.push(val);
          this.scheduleCountUpdate();
        },

        toggleMaterial(val) {
          const idx = this.materials.indexOf(val);
          if (idx >= 0) this.materials.splice(idx, 1);
          else this.materials.push(val);
          this.scheduleCountUpdate();
        },

        toggleColor(val) {
          const idx = this.colors.indexOf(val);
          if (idx >= 0) this.colors.splice(idx, 1);
          else this.colors.push(val);
          this.scheduleCountUpdate();
        },

        setMinPrice(val) {
          this.minPrice = Math.max(0, Math.min(val, this.maxPrice - 500));
          this.scheduleCountUpdate();
        },

        setMaxPrice(val) {
          this.maxPrice = Math.min(
            MAX_PRICE,
            Math.max(val, this.minPrice + 500),
          );
          this.scheduleCountUpdate();
        },

        clearAll() {
          this.sort = null;
          this.categories = [];
          this.materials = [];
          this.colors = [];
          this.minPrice = 0;
          this.maxPrice = MAX_PRICE;
          this.scheduleCountUpdate();
        },

        // Builds URL with only server-side-compatible filters (category, price, sort).
        // material_tag and color are `json` type in Supabase — PostgREST cannot filter
        // them directly, so those are applied client-side in applyClientFilters().
        buildServerUrl(select) {
          let url = `${SUPABASE_URL}/products?select=${select}`;

          if (this.categories.length === 1) {
            url += `&category=cs.${encodeURIComponent(JSON.stringify(this.categories))}`;
          } else if (this.categories.length > 1) {
            const orParts = this.categories.map(
              (c) => `category.cs.${JSON.stringify([c])}`,
            );
            url += `&or=${encodeURIComponent(`(${orParts.join(",")})`)}`;
          }

          if (this.minPrice > 0) url += `&regular_price=gte.${this.minPrice}`;
          if (this.maxPrice < MAX_PRICE)
            url += `&regular_price=lte.${this.maxPrice}`;

          if (this.sort === "newest") url += "&order=created_at.desc";
          else if (this.sort === "price_asc") url += "&order=regular_price.asc";
          else if (this.sort === "price_desc")
            url += "&order=regular_price.desc";

          return url;
        },

        scheduleCountUpdate() {
          this.countLoading = true;
          clearTimeout(this._countTimer);
          this._countTimer = setTimeout(() => this.fetchCount(), 400);
        },

        applyClientFilters(products) {
          let out = products;
          if (this.materials.length > 0) {
            out = out.filter((p) =>
              this.materials.some((m) => (p.material_tag || []).includes(m)),
            );
          }
          if (this.colors.length > 0) {
            out = out.filter((p) =>
              this.colors.some((c) => (p.color || []).includes(c)),
            );
          }
          return out;
        },

        async fetchCount() {
          try {
            const needsClientFilter =
              this.materials.length > 0 || this.colors.length > 0;
            if (needsClientFilter) {
              const url = this.buildServerUrl("id,material_tag,color");
              const res = await fetch(url, {
                headers: {
                  apikey: SUPABASE_KEY,
                  Authorization: `Bearer ${SUPABASE_KEY}`,
                },
              });
              const all = await res.json();
              this.resultCount = this.applyClientFilters(all).length;
            } else {
              const url = this.buildServerUrl("id");
              const res = await fetch(url, {
                headers: {
                  apikey: SUPABASE_KEY,
                  Authorization: `Bearer ${SUPABASE_KEY}`,
                  Prefer: "count=exact",
                  Range: "0-0",
                },
              });
              const cr = res.headers.get("content-range");
              this.resultCount = cr ? parseInt(cr.split("/")[1]) || 0 : 0;
            }
          } catch (_) {}
          this.countLoading = false;
        },

        async applyFilters() {
          this.panelOpen = false;

          const grid = document.getElementById("product-grid");
          const countEl = document.getElementById("product-count");
          const progressBar = document.getElementById("progress-bar");
          const loadMoreBtn = document.getElementById("load-more-btn");
          const paginationFooter = document.getElementById("pagination-footer");

          if (!grid) return;

          this.loading = true;
          grid.style.transition = "opacity 0.15s";
          grid.style.opacity = "0.4";

          try {
            // Fetch all server-side results (incl. material_tag + color for client filtering)
            const url = this.buildServerUrl(
              "id,title,subtitle,regular_price,member_price,image1,image2,material_tag,color",
            );
            const res = await fetch(url, {
              headers: {
                apikey: SUPABASE_KEY,
                Authorization: `Bearer ${SUPABASE_KEY}`,
              },
            });

            let all = await res.json();
            // Apply client-side material/color filters
            all = this.applyClientFilters(all);

            this._filteredProducts = all;
            const total = all.length;
            this.resultCount = total;

            const firstBatch = all.slice(0, PAGE_SIZE);
            this.offset = firstBatch.length;

            if (firstBatch.length > 0) {
              grid.innerHTML = firstBatch
                .map((p) => this.renderCard(p))
                .join("");
            } else {
              grid.innerHTML = `<div class="col-span-full flex items-center justify-center py-24"><p class="font-helv font-normal text-[14px] text-neutral-400">Ingen produkter matcher dine filtre.</p></div>`;
            }

            const shown = firstBatch.length;
            if (countEl)
              countEl.textContent = `Viser 1-${shown} ud af ${total} produkter`;
            if (progressBar)
              progressBar.style.width = `${total ? (shown / total) * 100 : 0}%`;
            if (paginationFooter)
              paginationFooter.classList.toggle("hidden", total === 0);
            if (loadMoreBtn) {
              loadMoreBtn.style.display = shown >= total ? "none" : "";
            }
          } catch (e) {
            console.error("Filter fetch error:", e);
          }

          grid.style.opacity = "1";
          this.loading = false;
        },

        async loadMore() {
          const grid = document.getElementById("product-grid");
          const countEl = document.getElementById("product-count");
          const progressBar = document.getElementById("progress-bar");
          const loadMoreBtn = document.getElementById("load-more-btn");

          if (!grid || this.loading) return;
          if (loadMoreBtn) loadMoreBtn.style.visibility = "hidden";
          this.loading = true;

          try {
            if (this._filteredProducts.length > 0) {
              // Client-side pagination from cached results
              const nextBatch = this._filteredProducts.slice(
                this.offset,
                this.offset + PAGE_SIZE,
              );
              nextBatch.forEach((p) => {
                grid.insertAdjacentHTML("beforeend", this.renderCard(p));
              });
              this.offset += nextBatch.length;
            } else {
              // Server-side pagination (initial load, no filters applied yet)
              const url = this.buildServerUrl(
                "id,title,subtitle,regular_price,member_price,image1,image2",
              );
              const from = this.offset;
              const to = this.offset + PAGE_SIZE - 1;
              const res = await fetch(url, {
                headers: {
                  apikey: SUPABASE_KEY,
                  Authorization: `Bearer ${SUPABASE_KEY}`,
                  Range: `${from}-${to}`,
                },
              });
              const newProducts = await res.json();
              newProducts.forEach((p) => {
                grid.insertAdjacentHTML("beforeend", this.renderCard(p));
              });
              this.offset += newProducts.length;
            }

            const shown = Math.min(this.offset, this.resultCount);
            if (countEl)
              countEl.textContent = `Viser 1-${shown} ud af ${this.resultCount} produkter`;
            if (progressBar)
              progressBar.style.width = `${this.resultCount ? (shown / this.resultCount) * 100 : 100}%`;
            if (loadMoreBtn) {
              if (this.offset >= this.resultCount) {
                loadMoreBtn.style.display = "none";
              } else {
                loadMoreBtn.style.display = "";
                loadMoreBtn.style.visibility = "visible";
              }
            }
          } catch (e) {
            console.error("Load more error:", e);
            if (loadMoreBtn) {
              loadMoreBtn.style.display = "";
              loadMoreBtn.style.visibility = "visible";
            }
          }

          this.loading = false;
        },

        renderCard(product) {
          const imageSrc =
            product.image1 ?? "https://placehold.co/600x750/f5f5f5/999999";
          const image2Src = product.image2 ?? null;
          const memberBadge = product.member_price
            ? `<div class="absolute bottom-0 right-0 bg-gray-100 px-2 py-1.5"><p class="font-ibm font-normal text-[12px]">MEDLEMSPRIS ${this.formatPrice(product.member_price)}</p></div>`
            : "";
          const hoverImg = image2Src
            ? `<img src="${image2Src}" alt="" aria-hidden="true" class="absolute inset-0 w-full h-full object-cover opacity-0 group-hover:opacity-100 transition-opacity duration-300" />`
            : "";

          return `<a href="/product/${product.id}" class="block group">
  <div class="relative overflow-hidden">
    <img src="${imageSrc}" alt="${product.title}" class="w-full aspect-[52/75] object-cover" />
    ${hoverImg}
    ${memberBadge}
  </div>
  <div class="mt-1 px-[4px]">
    <div class="flex justify-between items-baseline gap-2">
      <h3 class="font-helv font-medium text-[12px] uppercase">${product.title}</h3>
      <p class="font-ibm font-normal text-[12px] shrink-0">${this.formatPrice(product.regular_price)}</p>
    </div>
    <p class="font-helv font-normal text-[14px]">${product.subtitle}</p>
  </div>
</a>`;
        },
      };
    });
  });
</script>
