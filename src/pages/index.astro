---
import MainLayout from "../layouts/MainLayout.astro";
import Link from "../components/Link.astro";
import { Image } from "astro:assets";
import thumbsup from "../assets/images/thumbsup.png";
import Heading from "../components/Heading.astro";
import Text from "../components/Text.astro";
import Button from "../components/Button.astro";
---

<MainLayout title="Titel">
  <main class="container mx-auto p-4">
    <Text teksttype="brødtekst">Så bliver Anders glad:-)</Text>
    <Text>her er noget tekst</Text>
    <Heading htmlheading="h1" type="h1_large"> Om os </Heading>

    <Heading htmlheading="h1" type="h1_small"> Produktnavn </Heading>

    <Heading htmlheading="h2" type="h2_large"> Teamet bag Tusindfryd </Heading>

    <Heading htmlheading="h2" type="h2_medium"> Nyheder </Heading>

    <Heading htmlheading="h3" type="h3"> Mål & Materialer </Heading>

    <Heading htmlheading="h4" type="h4"> Kontakt </Heading>

    <Text teksttype="p_xsmall"> Bruges mest som oplysende p </Text>

    <Text teksttype="p_small"> Bruges til cta’s </Text>

    <Text teksttype="p_medium"> Bruges til p flere steder </Text>

    <Text teksttype="p_large" stylingclasses="underline underline-offset-4">
      Læs mere
    </Text>

    <Text teksttype="statement_large"> Neue Montreal Medium 30px </Text>

    <Text teksttype="price_small"> MEDLEMSPRIS 5.999 DKK </Text>

    <Text teksttype="price_large"> Medlemspris 5.999 DKK </Text>
  </main>
</MainLayout>
