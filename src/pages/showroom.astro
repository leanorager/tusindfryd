---
import MainLayout from "../layouts/MainLayout.astro";
import Text from "../components/Text.astro";
import ArrowLink from "../components/ArrowLink.astro";
import Heading from "../components/Heading.astro";

const fadeIn =
  "opacity-0 translate-y-6 intersect:opacity-100 intersect:translate-y-0 transition-all duration-700 intersect-once";
---

<MainLayout title="Showroom – Tusindfryd">
  <main>
    <section
      class="ShowroomEditorial md:!pt-12 !pb-16 md:!pb-24 bg-white md:relative px-container-mobile md:px-container py-3xl md:py-section"
    >
      <div class="mb-s md:mb-m">
        <Heading type="h1_small" stylingclasses={`max-w-[290px] ${fadeIn}`}>
          Kom forbi og oplev møblerne i virkeligheden.
        </Heading>
      </div>

      <!-- Mobil: åbningstider + adresse -->
      <div
        class="flex flex-col gap-xl mb-l md:hidden bg-gray-50 -mx-container-mobile px-container-mobile py-l"
      >
        <div class="flex flex-col gap-2xs">
          <Text
            teksttype="p_medium"
            stylingclasses="uppercase tracking-widest text-black"
            >Åbningstider</Text
          >
          <div class="border-t border-black pt-xs flex flex-col gap-2xs">
            <Text teksttype="p_medium">Tirsdag kl. 11–15</Text>
            <Text teksttype="p_medium">Torsdag kl. 14–18</Text>
            <Text teksttype="p_medium">Lørdag kl. 10–15</Text>
          </div>
        </div>
        <div class="flex flex-col gap-2xs">
          <Text
            teksttype="p_medium"
            stylingclasses="uppercase tracking-widest text-black">Adresse</Text
          >
          <div class="border-t border-black pt-xs flex flex-col gap-2xs">
            <Text teksttype="p_medium">Trindsøvej 10, Aarhus C</Text>
            <ArrowLink
              href="https://maps.google.com/?q=Trindsøvej+10,+8000+Aarhus+C"
              teksttype="p_large"
              target="_blank">Find vej her</ArrowLink
            >
          </div>
        </div>
      </div>

      <!-- Billeder -->
      <div
        class="grid grid-cols-2 md:grid-cols-3 gap-container-mobile md:gap-container items-start md:pr-[26%]"
      >
        <div class={`flex flex-col gap-2.5 ${fadeIn}`}>
          <img
            src="img/showroom_1.png"
            alt="Showroom"
            class="w-full h-44 md:h-[calc(100vh-480px)] object-cover"
          />
          <div class="flex flex-col gap-2xs">
            <Heading type="h3">Mærk det selv</Heading>
            <Text teksttype="p_medium" color="text-gray-500"
              >Billeder kan meget, men ikke alt. Kom forbi og sid i sofaen, mærk
              stolens træ og se farverne i det rigtige lys.</Text
            >
          </div>
        </div>

        <div class={`flex flex-col gap-xs md-gap-s delay-100 ${fadeIn}`}>
          <img
            src="img/showroom_2.png"
            alt="Værksted"
            class="w-full h-60 md:h-[calc(100vh-390px)] object-cover"
          />
          <div class="flex flex-col gap-2xs">
            <Heading type="h3">Lad dig inspirere af et levende univers</Heading>
            <Text teksttype="p_medium" color="text-gray-500"
              >Find ud af, hvad der passer til dit hjem.</Text
            >
          </div>
        </div>

        <div class={`flex flex-col gap-2.5 delay-200 ${fadeIn}`}>
          <img
            src="img/showroom_3.png"
            alt="Udvalget"
            class="w-full h-52 md:h-[calc(100vh-450px)] object-cover"
          />
          <div class="flex flex-col gap-2xs">
            <Heading type="h3">Nye fund, hele tiden</Heading>
            <Text teksttype="p_medium" color="text-gray-500"
              >Sortimentet skifter løbende. Det, du ser i dag, er måske væk i
              morgen — det er altid værd at kigge forbi.</Text
            >
          </div>
        </div>

        <!-- Desktop sidebar -->
        <div
          class="hidden md:flex absolute top-0 right-0 bottom-0 w-1/4 flex-col gap-xl bg-gray-50 px-container pt-section"
        >
          <div class="flex flex-col gap-2xs">
            <Text
              teksttype="p_medium"
              stylingclasses="uppercase tracking-widest text-black"
              >Åbningstider</Text
            >
            <div class="border-t border-black pt-xs flex flex-col gap-2xs">
              <Text teksttype="p_medium">Tirsdag kl. 11–15</Text>
              <Text teksttype="p_medium">Torsdag kl. 14–18</Text>
              <Text teksttype="p_medium">Lørdag kl. 10–15</Text>
            </div>
          </div>
          <div class="flex flex-col gap-2xs">
            <Text
              teksttype="p_medium"
              stylingclasses="uppercase tracking-widest text-black"
              >Adresse</Text
            >
            <div class="border-t border-black pt-xs flex flex-col gap-2xs">
              <Text teksttype="p_medium">Trindsøvej 10, Aarhus C</Text>
              <ArrowLink
                href="https://maps.google.com/?q=Trindsøvej+10,+8000+Aarhus+C"
                target="_blank"
                teksttype="p_large">Find vej her</ArrowLink
              >
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</MainLayout>
