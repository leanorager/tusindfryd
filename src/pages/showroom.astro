---
import MainLayout from "../layouts/MainLayout.astro";
import Text from "../components/Text.astro";
import ArrowLink from "../components/ArrowLink.astro";
import Heading from "../components/Heading.astro";
---

<style is:global>
  @keyframes fade-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .anim {
    opacity: 0;
    animation: fade-up 0.7s ease-out forwards;
  }
  .anim-1 {
    animation-delay: 0ms;
  }
  .anim-2 {
    animation-delay: 120ms;
  }
  .anim-3 {
    animation-delay: 240ms;
  }
  .anim-4 {
    animation-delay: 360ms;
  }
  .anim-5 {
    animation-delay: 480ms;
  }
</style>

<MainLayout
  title="Showroom – Tusindfryd"
  description="Besøg Tusindfryds showroom på Trindsøvej 10 i Aarhus C og oplev møblerne i virkeligheden. Åbent tirsdag 11–15, torsdag 14–18 og lørdag 10–15."
>
  <main>
    <section
      class="ShowroomEditorial md:!pt-12 !pb-16 md:!pb-24 bg-white md:relative px-container-mobile md:px-container py-3xl md:py-section"
    >
      <div class="mb-s md:mb-m">
        <Heading type="h1_small" stylingclasses="max-w-[290px] anim anim-1">
          Kom forbi og oplev møblerne i virkeligheden.
        </Heading>
      </div>

      <!-- Mobil: åbningstider + adresse -->
      <div
        class="flex flex-col gap-xl mb-l md:hidden bg-gray-50 -mx-container-mobile px-container-mobile py-l anim anim-2"
      >
        <div class="flex flex-col gap-2xs">
          <Text
            teksttype="p_medium"
            stylingclasses="uppercase tracking-widest text-black"
            >Åbningstider</Text
          >
          <div class="border-t border-black pt-xs flex flex-col gap-2xs">
            <Text teksttype="p_medium">Tirsdag kl. 11–15</Text>
            <Text teksttype="p_medium">Torsdag kl. 14–18</Text>
            <Text teksttype="p_medium">Lørdag kl. 10–15</Text>
          </div>
        </div>
        <div class="flex flex-col gap-2xs">
          <Text
            teksttype="p_medium"
            stylingclasses="uppercase tracking-widest text-black">Adresse</Text
          >
          <div class="border-t border-black pt-xs flex flex-col gap-2xs">
            <Text teksttype="p_medium">Trindsøvej 10, Aarhus C</Text>
            <ArrowLink
              href="https://maps.google.com/?q=Trindsøvej+10,+8000+Aarhus+C"
              teksttype="p_large"
              target="_blank">Find vej her</ArrowLink
            >
          </div>
        </div>
      </div>

      <!-- Billeder -->
      <div
        class="grid grid-cols-2 md:grid-cols-3 gap-container-mobile md:gap-container items-start md:pr-[26%]"
      >
        <div class="flex flex-col gap-2.5 anim anim-2">
          <div class="overflow-hidden">
            <img
              src="/img/showroom-1.webp"
              alt="Showroom"
              loading="lazy"
              class="w-full h-44 md:h-[calc(100vh-480px)] object-cover transition-transform duration-700 ease-out hover:scale-105"
            />
          </div>
          <div class="flex flex-col gap-2xs">
            <Heading type="h3">Mærk det selv</Heading>
            <Text teksttype="p_medium" color="text-gray-600"
              >Billeder kan meget, men ikke alt. Kom forbi og sid i sofaen, mærk
              stolens træ og se farverne i det rigtige lys.</Text
            >
          </div>
        </div>

        <div class="flex flex-col gap-xs md-gap-s anim anim-3">
          <div class="overflow-hidden">
            <img
              src="/img/showroom-2.webp"
              alt="Værksted"
              loading="lazy"
              class="w-full h-60 md:h-[calc(100vh-390px)] object-cover transition-transform duration-700 ease-out hover:scale-105"
            />
          </div>
          <div class="flex flex-col gap-2xs">
            <Heading type="h3">Lad dig inspirere af et levende univers</Heading>
            <Text teksttype="p_medium" color="text-gray-600"
              >Find ud af, hvad der passer til dit hjem.</Text
            >
          </div>
        </div>

        <div class="flex flex-col gap-2.5 anim anim-4">
          <div class="overflow-hidden">
            <img
              src="/img/showroom-3.webp"
              alt="Udvalget"
              loading="lazy"
              class="w-full h-52 md:h-[calc(100vh-450px)] object-cover transition-transform duration-700 ease-out hover:scale-105"
            />
          </div>
          <div class="flex flex-col gap-2xs">
            <Heading type="h3">Nye fund, hele tiden</Heading>
            <Text teksttype="p_medium" color="text-gray-600"
              >Sortimentet skifter løbende. Det, du ser i dag, er måske væk i
              morgen — det er altid værd at kigge forbi.</Text
            >
          </div>
        </div>

        <!-- Desktop sidebar -->
        <div
          class="hidden md:flex absolute top-0 right-0 bottom-0 w-1/4 flex-col gap-xl bg-gray-50 px-container pt-section anim anim-5"
        >
          <div class="flex flex-col gap-2xs">
            <Text
              teksttype="p_medium"
              stylingclasses="uppercase tracking-widest text-black"
              >Åbningstider</Text
            >
            <div class="border-t border-black pt-xs flex flex-col gap-2xs">
              <Text teksttype="p_medium">Tirsdag kl. 11–15</Text>
              <Text teksttype="p_medium">Torsdag kl. 14–18</Text>
              <Text teksttype="p_medium">Lørdag kl. 10–15</Text>
            </div>
          </div>
          <div class="flex flex-col gap-2xs">
            <Text
              teksttype="p_medium"
              stylingclasses="uppercase tracking-widest text-black"
              >Adresse</Text
            >
            <div class="border-t border-black pt-xs flex flex-col gap-2xs">
              <Text teksttype="p_medium">Trindsøvej 10, Aarhus C</Text>
              <ArrowLink
                href="https://maps.google.com/?q=Trindsøvej+10,+8000+Aarhus+C"
                target="_blank"
                teksttype="p_large">Find vej her</ArrowLink
              >
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</MainLayout>
