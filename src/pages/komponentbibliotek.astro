---
import MainLayout from "../layouts/MainLayout.astro";
import Heading from "../components/Heading.astro";
import Text from "../components/Text.astro";
import Link from "../components/Link.astro";
import Button from "../components/Button.astro";
import { Image } from "astro:assets";
import thumbsup from "../assets/images/thumbsup.png";
import ArrowLink from "../components/ArrowLink.astro";
import CTACard from "../components/CTACard.astro";
import TeamCard from "../components/TeamCard.astro";
import ShowroomBlock from "../components/ShowroomBlock.astro";
---

<MainLayout title="Titel">
  <main class="container mx-auto p-4">
    <Heading htmlheading="h1" size="large">Komponentbibliotek</Heading>
    <Text stylingclasses="italic"
      >Her kan du finde alle de komponenter, der er brugt i dette projekt.</Text
    >
    <hr class="my-4" />
    <!-- start på typografi -->
    <section>
      <Heading htmlheading="h2" size="medium">Typografi & ovesrkrifter</Heading>
      <Text
        >Her kan du finde alle de komponenter, der er brugt i dette projekt.</Text
      >
      <Heading htmlheading="h1" size="large">h1 - large - sans</Heading>
      <Heading htmlheading="h2" size="medium">h2 - medium - sans</Heading>
      <Heading htmlheading="h3" size="small">h3 - small - sans</Heading>
      <Heading htmlheading="h1" size="large" font="serif"
        >h1 - large - serif</Heading
      >
      <Heading htmlheading="h2" size="medium" font="serif"
        >h2 - medium - serif</Heading
      >
      <Heading htmlheading="h3" size="small" font="serif"
        >h3 - small - serif</Heading
      >
      <Heading htmlheading="h3" size="large" font="display"
        >h3 - large - display</Heading
      >
      <Text teksttype="brødtekst">
        Her er en sektion brødtekst: Lorem ipsum dolor, sit amet consectetur
        adipisicing elit. Ullam dolorem doloremque commodi eaque quisquam quasi
        recusandae veniam. Corporis totam <Link href="#">Default link: </Link> reiciendis
        quibusdam ratione iure aut, numquam tenetur voluptatem exercitationem sequi
        enim!
      </Text>
      <Text teksttype="konsultativ">
        Her en sektion konsultativ tekst: Lorem ipsum dolor, sit amet
        consectetur adipisicing elit. Ullam dolorem doloremque commodi eaque
        quisquam quasi recusandae veniam. Corporis totam reiciendis quibusdam
        ratione iure aut, numquam tenetur voluptatem exercitationem sequi enim!
      </Text>
      <Text teksttype="brødtekst" stylingclasses="italic">
        Her er en sektion brødtekst med ekstra css: Lorem ipsum dolor, sit amet
        consectetur adipisicing elit. Ullam dolorem doloremque commodi eaque
        quisquam quasi recusandae veniam. Corporis totam <Link href="#"
          >Default link:
        </Link> reiciendis quibusdam ratione iure aut, numquam tenetur voluptatem
        exercitationem sequi enim!
      </Text>
    </section>
    <!-- slut på typografi -->
    <hr class="my-4" />
    <!-- Link komponent instanser -->
    <section>
      <Heading htmlheading="h2" size="medium">Links</Heading>
      <Text><Link href="#">p_medium (default)</Link></Text>
      <Text><Link href="#" teksttype="p_xsmall">p_xsmall</Link></Text>
      <Text><Link href="#" teksttype="p_small">p_small</Link></Text>
      <Text><Link href="#" teksttype="p_large">p_large</Link></Text>
      <Text><Link href="#" teksttype="statement_small">statement_small</Link></Text>
      <Text><Link href="#" teksttype="statement_medium">statement_medium</Link></Text>
      <Text><Link href="#" teksttype="statement_bold">statement_bold</Link></Text>
      <Text><Link href="#" teksttype="statement_large">statement_large</Link></Text>
      <Text><Link href="#" teksttype="price_small">price_small</Link></Text>
      <Text><Link href="#" teksttype="price_large">price_large</Link></Text>
      <Text><Link href="#" teksttype="p_medium" stylingclasses="text-gray-400">Med stylingclasses (grå)</Link></Text>
      <Text><Link href="https://www.instagram.com" target="_blank" teksttype="p_medium">Ekstern link med target="_blank"</Link></Text>
    </section>
    <!-- Slut på Link komponent instanser -->

    <!-- ArrowLink komponent instanser -->
    <ArrowLink href="/" color="black" stylingclasses="w-[300px]">
      ArrowLink eksempel med custom bredde, black og target_self
    </ArrowLink>

    <ArrowLink href="/" color="white" stylingclasses="w-full bg-gray-500">
      ArrowLink eksempel med full width, white og target="_blank" - *grå
      baggrund for at kunne se hvid tekst.
    </ArrowLink>
    <!-- Slut på ArrowLink komponent instanser -->

    <hr class="my-4" />
    <!-- Buttons komponent instanser -->
    <section>
      <Heading htmlheading="h2" size="medium">Buttons</Heading>
      <Text><Button>Default knap</Button></Text>
      <Text><Button variant="primary">Button variant: primary</Button></Text>
      <Text
        ><Button variant="primary" size="small"
          >Button variant: primary size small</Button
        ></Text
      >
      <Text
        ><Button variant="primary" size="medium"
          >Button variant: primary size medium</Button
        ></Text
      >
      <Text
        ><Button variant="primary" size="large"
          >Button variant: primary size large</Button
        ></Text
      >
      <Text
        ><Button variant="secondary" size="small"
          >Button variant: secondary size small</Button
        ></Text
      >
      <Text
        ><Button variant="secondary" size="medium"
          >Button variant: secondary size medium</Button
        ></Text
      >
      <Text
        ><Button variant="secondary" size="large"
          >Variant: secondary size large</Button
        ></Text
      >
    </section>
    <!-- Slut på Buttons komponent instanser -->

    <!-- Start på CTACard komponent -->
    <CTACard
      image="https://placehold.co/375x630"
      href="/bliv-medlem"
      label="Bliv medlem og få fordele"
    />
    <!-- Slut på CTACard komponent -->

    <!-- Start på TeamCard komponent -->
    <TeamCard
      navn="John Doe"
      jobbeskrivelse="Some job description here"
      billede="https://placehold.co/364x497"
    />
    <!-- Slut på TeamCard komponent -->

    <!-- showroom block -->
    <ShowroomBlock
      image="https://placehold.co/600x400"
      imageAlt="Showroom billede"
      address="Trindsøvej 10 st 8000 Aarhus C"
    />
  </main>
</MainLayout>
