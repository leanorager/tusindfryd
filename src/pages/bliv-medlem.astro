---
import MainLayout from "../layouts/MainLayout.astro";
import Text from "../components/Text.astro";
import Link from "../components/Link.astro";
import Button from "../components/Button.astro";
import Heading from "../components/Heading.astro";
---

<MainLayout title="Bliv Medlem – Tusindfryd" description="Bliv medlem af Tusindfryd og få 10% rabat på alle varer, gratis fragt, pre-access til nye drops og levering inden for 1–3 dage." showFooter={false}>
  <main
    class="h-[calc(100vh-108px)] flex flex-col relative overflow-hidden"
    x-data="{
      step: 1,
      total: 6,
      plan: 'yearly',
      navn: '',
      email: '',
      telefon: '',
      kortnummer: '',
      udloeb: '',
      cvv: '',
      samtykke: false,
      confirmed: false,
      loading: false,
      planLabel() { return this.plan === 'yearly' ? '279 DKK / år' : '29 DKK / md' },
      next() { if (this.step < this.total) this.step++ },
      prev() { if (this.step > 1) this.step-- },
      submit() {
        if (!this.kortnummer || !this.udloeb || !this.cvv) return;
        this.confirmed = true;
      }
    }"
  >
    <!-- Baggrundsbillede -->
    <img
      src="img/member-cta.png"
      alt=""
      class="absolute inset-0 w-full h-full object-cover z-0"
    />
    <div class="absolute inset-0 bg-white/90 z-0"></div>

    <!-- Bekræftelse -->
    <div
      x-show="confirmed"
      x-transition:enter="transition ease-out duration-500"
      x-transition:enter-start="opacity-0 translate-y-4"
      x-transition:enter-end="opacity-100 translate-y-0"
      class="absolute inset-0 z-20 bg-white flex items-center justify-center px-5"
    >
      <div class="w-full max-w-[408px] flex flex-col gap-s">
        <Heading type="h1_small">
          Velkommen, <span x-text="navn.split(' ')[0]"></span>.
        </Heading>
        <Text teksttype="p_medium">
          Dit medlemsskab er aktiveret. Du modtager en bekræftelse på <span
            x-text="email"></span>.
        </Text>
        <Link href="/" stylingclasses="flex items-center gap-[10px] mt-s">
          Gå til shoppen <img
            src="/svg/arrow-black.svg"
            alt=""
            class="w-[25px] h-[10px]"
          />
        </Link>
      </div>
    </div>

    <!-- Progress bar -->
    <div
      class="h-px bg-gray-400 flex-shrink-0 relative z-10"
      x-show="!confirmed"
    >
      <div
        class="h-full bg-black transition-all duration-500 ease-out"
        :style="`width: ${(step / total) * 100}%`"
      >
      </div>
    </div>

    <!-- Step content -->
    <div
      class="flex-1 flex items-center justify-center px-5 overflow-hidden relative z-10"
      x-show="!confirmed"
    >
      <div class="w-full max-w-[408px]">
        <!-- Trin 1: Fordele + planvalg -->
        <div
          x-show="step === 1"
          x-transition:enter="transition ease-out duration-300"
          x-transition:enter-start="opacity-0 translate-y-3"
          x-transition:enter-end="opacity-100 translate-y-0"
        >
          <Text
            teksttype="p_xsmall"
            color="text-gray-500"
            stylingclasses="uppercase tracking-widest mb-2xs"
          >
            1 / 6
          </Text>
          <Heading htmlheading="h1" type="h1_small" stylingclasses="mb-m">
            Vælg dit medlemsskab
          </Heading>

          <!-- Fordele — <li> med flex-layout, <p> inde i <li> ville bryde gap-layoutet -->
          <ul class="flex flex-col gap-2xs mb-l">
            <li>
              <Text stylingclasses="flex items-start gap-xs">
                <span>—</span><span>10% rabat på alle ordrer</span>
              </Text>
            </li>
            <li>
              <Text stylingclasses="flex items-start gap-xs">
                <span>—</span><span>Gratis standardlevering</span></Text
              >
            </li>
            <li>
              <Text stylingclasses="flex items-start gap-xs">
                <span>—</span><span>Tidlig adgang til nye drops</span></Text
              >
            </li>
            <li>
              <Text stylingclasses="flex items-start gap-xs">
                <span>—</span><span
                  >Eksklusive tilbud og events i showroomet</span
                ></Text
              >
            </li>
            <li>
              <Text stylingclasses="flex items-start gap-xs">
                <span>—</span><span>Prioriteret adgang til begrænsede fund</span
                ></Text
              >
            </li>
          </ul>

          <!-- Planvalg — <span> inde i <button>, kan ikke bruge Text -->
          <div class="grid grid-cols-2 gap-xs mb-s">
            <button
              @click="plan = 'monthly'"
              class="flex flex-col p-s border text-left transition-all duration-150"
              :class="plan === 'monthly' ? 'border-black bg-black text-white' : 'border-gray-500 hover:border-gray-700'"
            >
              <span
                class="font-helv font-normal text-[13px] uppercase tracking-widest"
                :class="plan === 'monthly' ? 'text-white' : 'text-black'"
                >Månedlig</span
              >
              <span
                class="font-helv font-medium text-[25px] mb-xs"
                :class="plan === 'monthly' ? 'text-white' : 'text-black'"
                >39 DKK</span
              >
              <span
                class="font-helv font-normal text-[12px]"
                :class="plan === 'monthly' ? 'text-white' : 'text-black'"
                >pr. måned</span
              >
            </button>
            <button
              @click="plan = 'yearly'"
              class="flex flex-col p-s border text-left transition-all duration-150 relative"
              :class="plan === 'yearly' ? 'border-black bg-black text-white' : 'border-gray-500 hover:border-gray-700'"
            >
              <span
                class="font-helv font-normal text-[13px] uppercase tracking-widest"
                :class="plan === 'yearly' ? 'text-white' : 'text-black'"
                >Årlig</span
              >
              <span
                class="font-helv font-medium text-[25px] mb-xs"
                :class="plan === 'yearly' ? 'text-white' : 'text-black'"
                >279 DKK</span
              >
              <span
                class="font-helv font-normal text-[12px]"
                :class="plan === 'yearly' ? 'text-white' : 'text-black'"
                >pr. år — spar 189 DKK</span
              >
            </button>
          </div>
        </div>

        <!-- Trin 2: Navn -->
        <div
          x-show="step === 2"
          x-transition:enter="transition ease-out duration-300"
          x-transition:enter-start="opacity-0 translate-y-3"
          x-transition:enter-end="opacity-100 translate-y-0"
        >
          <Text
            teksttype="p_xsmall"
            color="text-gray-500"
            stylingclasses="uppercase tracking-widest mb-2xs">2 / 6</Text
          >
          <!-- <label> kan ikke indeholde <p> (Text renderer) — bruges raw -->
          <label
            for="navn"
            class="font-helv font-medium text-[25px] text-black block mb-m leading-tight"
          >
            Hvad hedder du?
          </label>
          <input
            type="text"
            id="navn"
            x-model="navn"
            placeholder="Fulde navn"
            @keydown.enter="navn && next()"
            class="w-full border-b border-gray-500 focus:border-black outline-none py-[15px] px-[20px] font-helv font-normal text-[13px] text-black bg-transparent placeholder:text-gray-500 transition-colors duration-150"
          />
        </div>

        <!-- Trin 3: E-mail -->
        <div
          x-show="step === 3"
          x-transition:enter="transition ease-out duration-300"
          x-transition:enter-start="opacity-0 translate-y-3"
          x-transition:enter-end="opacity-100 translate-y-0"
        >
          <Text
            teksttype="p_xsmall"
            color="text-gray-500"
            stylingclasses="uppercase tracking-widest mb-2xs">3 / 6</Text
          >
          <!-- <label> kan ikke indeholde <p> (Text renderer) — bruges raw -->
          <label
            for="email"
            class="font-helv font-medium text-[25px] text-black block mb-m leading-tight"
          >
            Hvad er din e-mailadresse?
          </label>
          <input
            type="email"
            id="email"
            x-model="email"
            placeholder="sara@email.dk"
            @keydown.enter="email && next()"
            class="w-full border-b border-gray-500 focus:border-black outline-none py-[15px] px-[20px] font-helv font-normal text-[13px] text-black bg-transparent placeholder:text-gray-500 transition-colors duration-150"
          />
        </div>

        <!-- Trin 4: Telefon -->
        <div
          x-show="step === 4"
          x-transition:enter="transition ease-out duration-300"
          x-transition:enter-start="opacity-0 translate-y-3"
          x-transition:enter-end="opacity-100 translate-y-0"
        >
          <Text
            teksttype="p_xsmall"
            color="text-gray-500"
            stylingclasses="uppercase tracking-widest mb-2xs">4 / 6</Text
          >
          <!-- <label> kan ikke indeholde <p> (Text renderer) — bruges raw -->
          <label
            for="telefon"
            class="font-helv font-medium text-[25px] text-black block mb-m leading-tight"
          >
            Hvad er dit telefonnummer?
          </label>

          <input
            type="tel"
            id="telefon"
            x-model="telefon"
            placeholder="+45 12 34 56 78"
            @keydown.enter="next()"
            class="w-full border-b border-gray-500 focus:border-black outline-none py-[15px] px-[20px] font-helv font-normal text-[13px] text-black bg-transparent placeholder:text-gray-500 transition-colors duration-150"
          />
        </div>

        <!-- Trin 5: Opsummering + samtykke -->
        <div
          x-show="step === 5"
          x-transition:enter="transition ease-out duration-300"
          x-transition:enter-start="opacity-0 translate-y-3"
          x-transition:enter-end="opacity-100 translate-y-0"
        >
          <Text
            teksttype="p_xsmall"
            color="text-gray-500"
            stylingclasses="uppercase tracking-widest mb-2xs">5 / 6</Text
          >
          <Heading
            htmlheading="h1"
            type="h1_small"
            stylingclasses="mb-m leading-tight"
          >
            Næsten der, <span x-text="navn.split(' ')[0]"></span>.
          </Heading>
          <div
            class="flex flex-col gap-xs border-t border-b border-gray-400 py-m mb-m"
          >
            <Text stylingclasses="flex justify-between">
              <span>Tusindfryd Medlemsskab</span>
              <span x-text="planLabel()"></span>
            </Text>
            <Text color="text-gray-500">
              Fornyes automatisk — kan opsiges til enhver tid
            </Text>
          </div>
          <!-- <label> med links inde — <p> er ugyldig i <label> og linkene har unik hover-farve -->
          <div class="flex items-start gap-s mb-s">
            <input
              type="checkbox"
              id="samtykke"
              x-model="samtykke"
              class="mt-0.5 w-3.5 h-3.5 border border-gray-500 accent-black flex-shrink-0"
            />
            <label
              for="samtykke"
              class="font-helv font-normal text-[12px] text-gray-500 leading-relaxed"
            >
              Jeg accepterer Tusindfryd's
              <a
                href="/juridisk#handelsbetingelser"
                class="underline hover:text-black transition-colors duration-150"
                >handelsbetingelser</a
              >
              og
              <a
                href="/juridisk#privatlivspolitik"
                class="underline hover:text-black transition-colors duration-150"
                >privatlivspolitik</a
              >
            </label>
          </div>
        </div>

        <!-- Trin 6: Betaling -->
        <div
          x-show="step === 6"
          x-transition:enter="transition ease-out duration-300"
          x-transition:enter-start="opacity-0 translate-y-3"
          x-transition:enter-end="opacity-100 translate-y-0"
        >
          <Text
            teksttype="p_xsmall"
            color="text-gray-500"
            stylingclasses="uppercase tracking-widest mb-2xs">6 / 6</Text
          >
          <Heading
            htmlheading="h1"
            type="h1_small"
            stylingclasses="mb-l leading-tight"
          >
            Kortoplysninger
          </Heading>
          <div class="flex flex-col gap-m mb-m">
            <div>
              <!-- <label> kan ikke indeholde <p> (Text renderer) — bruges raw -->
              <label
                for="kortnummer"
                class="font-helv font-normal text-[14px] text-gray-500 block mb-xs"
                >Kortnummer</label
              >
              <input
                type="text"
                id="kortnummer"
                x-model="kortnummer"
                placeholder="1234 5678 9012 3456"
                maxlength="19"
                class="w-full border-b border-gray-500 focus:border-black outline-none py-[15px] px-[20px] font-helv font-normal text-[13px] text-black bg-transparent placeholder:text-gray-500 transition-colors duration-150"
              />
            </div>
            <div class="grid grid-cols-2 gap-6">
              <div>
                <label
                  for="udloeb"
                  class="font-helv font-normal text-[14px] text-gray-500 block mb-xs"
                  >Udløbsdato</label
                >
                <input
                  type="text"
                  id="udloeb"
                  x-model="udloeb"
                  placeholder="MM/ÅÅ"
                  maxlength="5"
                  class="w-full border-b border-gray-500 focus:border-black outline-none py-[15px] px-[20px] font-helv font-normal text-[13px] text-black bg-transparent placeholder:text-gray-500 transition-colors duration-150"
                />
              </div>
              <div>
                <label
                  for="cvv"
                  class="font-helv font-normal text-[14px] text-gray-500 block mb-xs"
                  >CVV</label
                >
                <input
                  type="text"
                  id="cvv"
                  x-model="cvv"
                  placeholder="123"
                  maxlength="3"
                  class="w-full border-b border-gray-500 focus:border-black outline-none py-[15px] px-[20px] font-helv font-normal text-[13px] text-black bg-transparent placeholder:text-gray-500 transition-colors duration-150"
                />
              </div>
            </div>
          </div>
          <Button
            variant="primary"
            type="button"
            @click="submit()"
            :disabled="!kortnummer || !udloeb || !cvv || loading"
            stylingclasses="disabled:opacity-30 disabled:cursor-not-allowed"
            x-text="loading ? 'Behandler...' : `Betal – ${planLabel()}`"
          />
        </div>

        <!-- Navigation -->
        <div
          class="mt-s flex justify-end items-center gap-m"
          x-show="!confirmed && step < 6"
        >
          <button
            x-show="step > 1"
            @click="prev()"
            class="font-helv font-normal text-[13px] text-gray-500 flex items-center gap-[10px] cursor-pointer hover:text-black transition-colors duration-150"
          >
            <img
              src="/svg/arrow-black.svg"
              alt=""
              class="w-[25px] h-[10px] rotate-180 opacity-40"
            />
            Tilbage
          </button>
          <button
            @click="next()"
            :disabled="(step === 2 && !navn) || (step === 3 && !email) || (step === 5 && !samtykke)"
            class="font-helv font-medium text-[13px] text-black flex items-center gap-[10px] cursor-pointer disabled:opacity-30 disabled:cursor-not-allowed"
          >
            Forsæt <img
              src="/svg/arrow-black.svg"
              alt=""
              class="w-[25px] h-[10px]"
            />
          </button>
        </div>
      </div>
    </div>
  </main>
</MainLayout>
