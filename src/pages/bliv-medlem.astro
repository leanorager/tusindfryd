---
import MainLayout from "../layouts/MainLayout.astro";
import Text from "../components/Text.astro";
import Link from "../components/Link.astro";
import Button from "../components/Button.astro";
---

<MainLayout title="Bliv Medlem – Tusindfryd" showFooter={false}>
  <main
    class="h-[calc(100vh-108px)] flex flex-col relative overflow-hidden"
    x-data="{
      step: 1,
      total: 6,
      plan: 'yearly',
      navn: '',
      email: '',
      telefon: '',
      kortnummer: '',
      udloeb: '',
      cvv: '',
      samtykke: false,
      confirmed: false,
      loading: false,
      planLabel() { return this.plan === 'yearly' ? '279 DKK / år' : '29 DKK / md' },
      next() { if (this.step < this.total) this.step++ },
      prev() { if (this.step > 1) this.step-- },
      async submit() {
        if (!this.kortnummer || !this.udloeb || !this.cvv || this.loading) return;
        this.loading = true;
        const res = await fetch('/api/bliv-medlem', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ navn: this.navn, email: this.email, plan: this.plan })
        });
        this.loading = false;
        if (res.ok) this.confirmed = true;
      }
    }"
  >
    <!-- Baggrundsbillede -->
    <img
      src="/medlem-bg.png"
      alt=""
      class="absolute inset-0 w-full h-full object-cover z-0"
    />
    <div class="absolute inset-0 bg-white/85 z-0"></div>

    <!-- Bekræftelse -->
    <div
      x-show="confirmed"
      x-transition:enter="transition ease-out duration-500"
      x-transition:enter-start="opacity-0 translate-y-4"
      x-transition:enter-end="opacity-100 translate-y-0"
      class="absolute inset-0 z-20 bg-white flex items-center justify-center px-5"
    >
      <div class="w-full max-w-[560px] flex flex-col gap-6">
        <Text teksttype="statement_large" stylingclasses="leading-tight">
          Velkommen,<br /><span x-text="navn.split(' ')[0]"></span>.
        </Text>
        <Text
          teksttype="p_large"
          color="text-gray-500"
          stylingclasses="max-w-xs"
        >
          Dit medlemsskab er aktiveret. Du modtager en bekræftelse på <span
            x-text="email"
            class="text-black"></span>.
        </Text>
        <Link href="/" stylingclasses="flex items-center gap-2 mt-2">
          Gå til shoppen <img
            src="/svg/ArrowBlack.svg"
            alt=""
            class="w-[25px] h-[10px]"
          />
        </Link>
      </div>
    </div>

    <!-- Progress bar -->
    <div
      class="h-px bg-gray-400 flex-shrink-0 relative z-10"
      x-show="!confirmed"
    >
      <div
        class="h-full bg-black transition-all duration-500 ease-out"
        :style="`width: ${(step / total) * 100}%`"
      >
      </div>
    </div>

    <!-- Step content -->
    <div
      class="flex-1 flex items-center justify-center px-5 overflow-hidden relative z-10"
      x-show="!confirmed"
    >
      <div class="w-full max-w-[560px]">
        <!-- Trin 1: Fordele + planvalg -->
        <div
          x-show="step === 1"
          x-transition:enter="transition ease-out duration-300"
          x-transition:enter-start="opacity-0 translate-y-3"
          x-transition:enter-end="opacity-100 translate-y-0"
          x-transition:leave="transition ease-in duration-150"
          x-transition:leave-start="opacity-100"
          x-transition:leave-end="opacity-0"
        >
          <Text
            teksttype="p_xsmall"
            color="text-gray-500"
            stylingclasses="uppercase tracking-widest mb-4"
          >
            1 / 6
          </Text>
          <Text teksttype="statement_large" stylingclasses="mb-6 leading-tight">
            Vælg dit medlemsskab
          </Text>

          <!-- Fordele — <li> med flex-layout, <p> inde i <li> ville bryde gap-layoutet -->
          <ul class="flex flex-col gap-2 mb-8">
            <li
              class="flex items-start gap-3 font-helv font-light text-sm text-black"
            >
              <span class="text-gray-500">—</span><span
                >10% rabat på alle ordrer</span
              >
            </li>
            <li
              class="flex items-start gap-3 font-helv font-light text-sm text-black"
            >
              <span class="text-gray-500">—</span><span
                >Gratis standardlevering</span
              >
            </li>
            <li
              class="flex items-start gap-3 font-helv font-light text-sm text-black"
            >
              <span class="text-gray-500">—</span><span
                >Tidlig adgang til nye drops</span
              >
            </li>
            <li
              class="flex items-start gap-3 font-helv font-light text-sm text-black"
            >
              <span class="text-gray-500">—</span><span
                >Eksklusive tilbud og events i showroomet</span
              >
            </li>
            <li
              class="flex items-start gap-3 font-helv font-light text-sm text-black"
            >
              <span class="text-gray-500">—</span><span
                >Prioriteret adgang til begrænsede fund</span
              >
            </li>
          </ul>

          <!-- Planvalg — <span> inde i <button>, kan ikke bruge Text -->
          <div class="grid grid-cols-2 gap-3 mb-8">
            <button
              @click="plan = 'monthly'"
              class="flex flex-col gap-1 p-4 border text-left transition-all duration-150"
              :class="plan === 'monthly' ? 'border-black bg-black text-white' : 'border-gray-500 hover:border-gray-700'"
            >
              <span
                class="font-helv font-light text-xs uppercase tracking-widest"
                :class="plan === 'monthly' ? 'text-gray-300' : 'text-gray-500'"
                >Månedlig</span
              >
              <span
                class="font-mont font-medium text-xl"
                :class="plan === 'monthly' ? 'text-white' : 'text-black'"
                >29 DKK</span
              >
              <span
                class="font-helv font-light text-xs"
                :class="plan === 'monthly' ? 'text-gray-300' : 'text-gray-500'"
                >pr. måned</span
              >
            </button>
            <button
              @click="plan = 'yearly'"
              class="flex flex-col gap-1 p-4 border text-left transition-all duration-150 relative"
              :class="plan === 'yearly' ? 'border-black bg-black text-white' : 'border-gray-500 hover:border-gray-700'"
            >
              <span
                class="font-helv font-light text-xs uppercase tracking-widest"
                :class="plan === 'yearly' ? 'text-gray-300' : 'text-gray-500'"
                >Årlig</span
              >
              <span
                class="font-mont font-medium text-xl"
                :class="plan === 'yearly' ? 'text-white' : 'text-black'"
                >279 DKK</span
              >
              <span
                class="font-helv font-light text-xs"
                :class="plan === 'yearly' ? 'text-gray-300' : 'text-gray-500'"
                >pr. år — spar 69 DKK</span
              >
            </button>
          </div>

          <Button
            variant="textlink"
            @click="next()"
            stylingclasses="flex items-center gap-2"
          >
            Fortsæt <img
              src="/svg/ArrowBlack.svg"
              alt=""
              class="w-[25px] h-[10px]"
            />
          </Button>
        </div>

        <!-- Trin 2: Navn -->
        <div
          x-show="step === 2"
          x-transition:enter="transition ease-out duration-300"
          x-transition:enter-start="opacity-0 translate-y-3"
          x-transition:enter-end="opacity-100 translate-y-0"
          x-transition:leave="transition ease-in duration-150"
          x-transition:leave-start="opacity-100"
          x-transition:leave-end="opacity-0"
        >
          <Text
            teksttype="p_xsmall"
            color="text-gray-500"
            stylingclasses="uppercase tracking-widest mb-4">2 / 6</Text
          >
          <!-- <label> kan ikke indeholde <p> (Text renderer) — bruges raw -->
          <label
            for="navn"
            class="font-mont font-medium text-3xl md:text-4xl text-black block mb-8 leading-tight"
          >
            Hvad hedder du?
          </label>
          <input
            type="text"
            id="navn"
            x-model="navn"
            placeholder="Fulde navn"
            @keydown.enter="navn && next()"
            class="w-full border-b border-gray-500 focus:border-black outline-none py-3 font-helv font-light text-lg text-black bg-transparent placeholder:text-gray-500 transition-colors duration-150"
          />
          <Button
            variant="textlink"
            @click="next()"
            :disabled="!navn"
            stylingclasses="mt-8 flex items-center gap-2 disabled:opacity-30 disabled:cursor-not-allowed"
          >
            Næste <img
              src="/svg/ArrowBlack.svg"
              alt=""
              class="w-[25px] h-[10px]"
            />
          </Button>
        </div>

        <!-- Trin 3: E-mail -->
        <div
          x-show="step === 3"
          x-transition:enter="transition ease-out duration-300"
          x-transition:enter-start="opacity-0 translate-y-3"
          x-transition:enter-end="opacity-100 translate-y-0"
          x-transition:leave="transition ease-in duration-150"
          x-transition:leave-start="opacity-100"
          x-transition:leave-end="opacity-0"
        >
          <Text
            teksttype="p_xsmall"
            color="text-gray-500"
            stylingclasses="uppercase tracking-widest mb-4">3 / 6</Text
          >
          <!-- <label> kan ikke indeholde <p> (Text renderer) — bruges raw -->
          <label
            for="email"
            class="font-mont font-medium text-3xl md:text-4xl text-black block mb-8 leading-tight"
          >
            Hvad er din e-mailadresse?
          </label>
          <input
            type="email"
            id="email"
            x-model="email"
            placeholder="sara@email.dk"
            @keydown.enter="email && next()"
            class="w-full border-b border-gray-500 focus:border-black outline-none py-3 font-helv font-light text-lg text-black bg-transparent placeholder:text-gray-500 transition-colors duration-150"
          />
          <Button
            variant="textlink"
            @click="next()"
            :disabled="!email"
            stylingclasses="mt-8 flex items-center gap-2 disabled:opacity-30 disabled:cursor-not-allowed"
          >
            Næste <img
              src="/svg/ArrowBlack.svg"
              alt=""
              class="w-[25px] h-[10px]"
            />
          </Button>
        </div>

        <!-- Trin 4: Telefon -->
        <div
          x-show="step === 4"
          x-transition:enter="transition ease-out duration-300"
          x-transition:enter-start="opacity-0 translate-y-3"
          x-transition:enter-end="opacity-100 translate-y-0"
          x-transition:leave="transition ease-in duration-150"
          x-transition:leave-start="opacity-100"
          x-transition:leave-end="opacity-0"
        >
          <Text
            teksttype="p_xsmall"
            color="text-gray-500"
            stylingclasses="uppercase tracking-widest mb-4">4 / 6</Text
          >
          <!-- <label> kan ikke indeholde <p> (Text renderer) — bruges raw -->
          <label
            for="telefon"
            class="font-mont font-medium text-3xl md:text-4xl text-black block mb-2 leading-tight"
          >
            Hvad er dit telefonnummer?
          </label>
          <Text teksttype="p_xsmall" color="text-gray-500" stylingclasses="mb-8"
            >Valgfrit</Text
          >
          <input
            type="tel"
            id="telefon"
            x-model="telefon"
            placeholder="+45 12 34 56 78"
            @keydown.enter="next()"
            class="w-full border-b border-gray-500 focus:border-black outline-none py-3 font-helv font-light text-lg text-black bg-transparent placeholder:text-gray-500 transition-colors duration-150"
          />
          <div class="mt-8 flex items-center gap-6">
            <Button
              variant="textlink"
              @click="next()"
              stylingclasses="flex items-center gap-2"
            >
              Næste <img
                src="/svg/ArrowBlack.svg"
                alt=""
                class="w-[25px] h-[10px]"
              />
            </Button>
            <Button
              variant="plain"
              @click="next()"
              stylingclasses="!text-gray-500 hover:text-black transition-colors duration-150"
            >
              Spring over
            </Button>
          </div>
        </div>

        <!-- Trin 5: Opsummering + samtykke -->
        <div
          x-show="step === 5"
          x-transition:enter="transition ease-out duration-300"
          x-transition:enter-start="opacity-0 translate-y-3"
          x-transition:enter-end="opacity-100 translate-y-0"
          x-transition:leave="transition ease-in duration-150"
          x-transition:leave-start="opacity-100"
          x-transition:leave-end="opacity-0"
        >
          <Text
            teksttype="p_xsmall"
            color="text-gray-500"
            stylingclasses="uppercase tracking-widest mb-4">5 / 6</Text
          >
          <Text teksttype="statement_large" stylingclasses="mb-8 leading-tight">
            Næsten der, <span x-text="navn.split(' ')[0]"></span>.
          </Text>
          <div class="flex flex-col gap-3 border-t border-b border-gray-400 py-5 mb-6">
            <Text teksttype="p_large" stylingclasses="flex justify-between">
              <span>Tusindfryd Medlemsskab</span>
              <span x-text="planLabel()"></span>
            </Text>
            <Text teksttype="p_xsmall" color="text-gray-500">
              Fornyes automatisk — opsiges til enhver tid
            </Text>
          </div>
          <!-- <label> med links inde — <p> er ugyldig i <label> og linkene har unik hover-farve -->
          <div class="flex items-start gap-3 mb-6">
            <input
              type="checkbox"
              id="samtykke"
              x-model="samtykke"
              class="mt-0.5 w-3.5 h-3.5 border border-gray-500 accent-black flex-shrink-0"
            />
            <label for="samtykke" class="font-helv font-light text-xs text-gray-500 leading-relaxed">
              Jeg accepterer Tusindfryd's
              <a href="/juridisk#handelsbetingelser" class="underline hover:text-black transition-colors duration-150">handelsbetingelser</a>
              og
              <a href="/juridisk#privatlivspolitik" class="underline hover:text-black transition-colors duration-150">privatlivspolitik</a>
            </label>
          </div>
          <Button
            variant="textlink"
            @click="next()"
            :disabled="!samtykke"
            stylingclasses="flex items-center gap-2 disabled:opacity-30 disabled:cursor-not-allowed"
          >
            Gå til betaling <img src="/svg/ArrowBlack.svg" alt="" class="w-[25px] h-[10px]" />
          </Button>
        </div>

        <!-- Trin 6: Betaling -->
        <div
          x-show="step === 6"
          x-transition:enter="transition ease-out duration-300"
          x-transition:enter-start="opacity-0 translate-y-3"
          x-transition:enter-end="opacity-100 translate-y-0"
          x-transition:leave="transition ease-in duration-150"
          x-transition:leave-start="opacity-100"
          x-transition:leave-end="opacity-0"
        >
          <Text
            teksttype="p_xsmall"
            color="text-gray-500"
            stylingclasses="uppercase tracking-widest mb-4">6 / 6</Text
          >
          <Text teksttype="statement_large" stylingclasses="mb-8 leading-tight">
            Kortoplysninger
          </Text>
          <div class="flex flex-col gap-6 mb-8">
            <div>
              <!-- <label> kan ikke indeholde <p> (Text renderer) — bruges raw -->
              <label for="kortnummer" class="font-helv font-normal text-[12px] text-gray-500 uppercase tracking-widest block mb-2">Kortnummer</label>
              <input
                type="text"
                id="kortnummer"
                x-model="kortnummer"
                placeholder="1234 5678 9012 3456"
                maxlength="19"
                class="w-full border-b border-gray-500 focus:border-black outline-none py-3 font-helv font-light text-lg text-black bg-transparent placeholder:text-gray-500 transition-colors duration-150"
              />
            </div>
            <div class="grid grid-cols-2 gap-6">
              <div>
                <label for="udloeb" class="font-helv font-normal text-[12px] text-gray-500 uppercase tracking-widest block mb-2">Udløbsdato</label>
                <input
                  type="text"
                  id="udloeb"
                  x-model="udloeb"
                  placeholder="MM/ÅÅ"
                  maxlength="5"
                  class="w-full border-b border-gray-500 focus:border-black outline-none py-3 font-helv font-light text-lg text-black bg-transparent placeholder:text-gray-500 transition-colors duration-150"
                />
              </div>
              <div>
                <label for="cvv" class="font-helv font-normal text-[12px] text-gray-500 uppercase tracking-widest block mb-2">CVV</label>
                <input
                  type="text"
                  id="cvv"
                  x-model="cvv"
                  placeholder="123"
                  maxlength="3"
                  class="w-full border-b border-gray-500 focus:border-black outline-none py-3 font-helv font-light text-lg text-black bg-transparent placeholder:text-gray-500 transition-colors duration-150"
                />
              </div>
            </div>
          </div>
          <Button
            variant="primary"
            type="button"
            @click="submit()"
            :disabled="!kortnummer || !udloeb || !cvv || loading"
            stylingclasses="disabled:opacity-30 disabled:cursor-not-allowed"
            x-text="loading ? 'Behandler...' : `Betal – ${planLabel()}`"
          />
        </div>
      </div>
    </div>

    <!-- Tilbage -->
    <div
      class="px-5 pb-8 flex-shrink-0 h-12 flex items-center relative z-10"
      x-show="!confirmed"
    >
      <Button
        variant="plain"
        x-show="step > 1"
        @click="prev()"
        stylingclasses="!text-black transition-colors duration-150 flex items-center gap-1 !text-xs"
      >
        <img
          src="/svg/ArrowBlack.svg"
          alt=""
          class="w-[25px] h-[10px] rotate-180"
        /> Tilbage
      </Button>
    </div>
  </main>
</MainLayout>
